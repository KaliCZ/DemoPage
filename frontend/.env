# Production / custom Supabase:
# PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Local Supabase (started automatically by the Aspire AppHost — see aspire/Kalandra.AppHost/DevInfrastructure.cs):
PUBLIC_SUPABASE_URL=http://localhost:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# In dev, API calls go through Vite's proxy (see astro.config.mjs) — no cross-origin, no preflight.
# In production, set this to the real API URL (e.g. https://api.kalandra.tech).
PUBLIC_API_URL=

# Cloudflare Turnstile — test keys that always pass (https://developers.cloudflare.com/turnstile/troubleshooting/testing/)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Production:
# PUBLIC_TURNSTILE_SITE_KEY=your-real-site-key

# Sentry — error tracking, structured logs, traces, and session replay (@sentry/browser, npm SDK).
# Browser DSNs are public credentials — Sentry protects them via the per-project Allowed Domains
# list (Settings → Projects → <project> → Client Keys), not by hiding the DSN. So we commit it.
# Empty value → SDK is tree-shaken out of the bundle at build time and never initialises.
PUBLIC_SENTRY_DSN=https://2f7cd4e37546d8be1238fd1e7afaaf72@o4511422312284160.ingest.de.sentry.io/4511422317920336

# Optional override for Sentry's `environment` tag. Defaults to Vite's MODE ("development" in
# `astro dev`, "production" in `astro build`). CI test jobs build with PUBLIC_SENTRY_DSN="" so
# the SDK is tree-shaken out entirely — they don't need an environment tag.
# PUBLIC_SENTRY_ENVIRONMENT=
