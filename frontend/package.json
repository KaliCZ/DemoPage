{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development astro dev --open",
    "dev:claudePreview": "cross-env NODE_ENV=development VITE_STRICT_PORT=1 astro dev",
    "prebuild": "playwright install chromium && node scripts/generate-cv-pdf.mjs",
    "build": "astro build",
    "build:cv": "node scripts/generate-cv-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "test:install": "playwright install chromium",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "serve": "serve dist -l 4321",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/material-symbols": "^1.2.74",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-document-load": "^0.63.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/browser": "^10.54.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.8",
    "astro-icon": "^1.1.5",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/qrcode": "^1.5.6",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "serve": "^14.2.6"
  }
}
