---
// Observability loader — Sentry is initialised via the @sentry/browser npm SDK from
// src/lib/observability.ts (imported by Layout.astro). This component now only handles
// BetterStack's loader script, kept as an opt-in dual-write path via PUBLIC_BETTERSTACK_TOKEN.

const betterstackToken = import.meta.env.PUBLIC_BETTERSTACK_TOKEN;
const mode = import.meta.env.MODE;

// Build-time safety: production deploys must ship with Sentry wired up. Missing DSN in dev is fine —
// `npm run dev` / Aspire runs without one so contributors don't need a Sentry account to iterate.
if (import.meta.env.PROD && !import.meta.env.PUBLIC_SENTRY_DSN) {
  throw new Error(
    "PUBLIC_SENTRY_DSN must be set when building for production. " +
      "CI provides it via the FRONTEND_SENTRY_DSN GitHub secret; for a local prod build, set it in frontend/.env.local.",
  );
}
---

{/* Side-effect import — initialises Sentry as early as Astro will hoist this <head> script. */}
<script>
  import "../lib/observability";
</script>

{
  betterstackToken && (
    <script is:inline define:vars={{ bsToken: betterstackToken, env: mode }}>
      {`
        !(function (b, e, t, r) {
          b[t] = b[t] || function () { (b[t].q = b[t].q || []).push(arguments); };
          b[t].l = +new Date();
          var s = e.createElement("script");
          s.async = 1;
          s.crossOrigin = "anonymous";
          s.src = "https://betterstack.net/b.js?t=" + r;
          (e.head || e.getElementsByTagName("head")[0]).appendChild(s);
        })(window, document, "betterstack", bsToken);
        betterstack("config", {
          sentry: {
            tracePropagationTargets: ["localhost", /^\\/api\\//, "https://api.kalandra.tech"],
          },
        });
        betterstack("init", { environment: env });
      `}
    </script>
  )
}
