---
interface Props {
  t: {
    browser: string;
    staticSite: string;
    dns: string;
    reverseProxy: string;
    active: string;
    standby: string;
    backgroundJobs: string;
    database: string;
    authentication: string;
    cicd: string;
    pipeline: string;
  };
  class?: string;
}

const { t, class: className, ...rest } = Astro.props;
---

<div class:list={["overflow-x-auto", className]} {...rest}>
  <svg
    viewBox="0 0 1080 560"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full min-w-[700px]"
    role="img"
    aria-label="Architecture diagram"
  >
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6" fill="var(--color-outline)" />
      </marker>
      <marker id="arrow-muted" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <path d="M0,0 L8,3 L0,6" fill="var(--color-outline-variant)" />
      </marker>
    </defs>

    <!-- ===== BROWSER ===== -->
    <g>
      <rect x="75" y="8" width="170" height="44" rx="8"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <text x="160" y="35" text-anchor="middle"
        fill="var(--color-on-surface)" font-family="var(--font-headline)" font-size="14" font-weight="600">
        {t.browser}
      </text>
    </g>

    <!-- Arrow: Browser → Cloudflare -->
    <line x1="160" y1="52" x2="160" y2="80"
      stroke="var(--color-outline)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- ===== CLOUDFLARE CONTAINER ===== -->
    <g>
      <rect x="20" y="88" width="270" height="252" rx="12"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <rect x="20" y="88" width="270" height="5" rx="2.5"
        fill="var(--color-primary)" />
      <text x="155" y="118" text-anchor="middle"
        fill="var(--color-on-surface-variant)" font-family="var(--font-label)" font-size="11" font-weight="700" letter-spacing="1.5" text-transform="uppercase">
        CLOUDFLARE
      </text>

      <!-- Static Site -->
      <g>
        <rect x="40" y="135" width="230" height="50" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="40" y="135" width="4" height="50" rx="2"
          fill="var(--color-primary)" />
        <circle cx="58" cy="155" r="3.5" fill="var(--color-primary)" opacity="0.6" />
        <text x="68" y="159"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          Astro
        </text>
        <text x="56" y="176"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.staticSite}
        </text>
      </g>

      <!-- DNS -->
      <g>
        <rect x="40" y="200" width="230" height="50" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="40" y="200" width="4" height="50" rx="2"
          fill="var(--color-primary)" />
        <circle cx="58" cy="220" r="3.5" fill="var(--color-primary)" opacity="0.6" />
        <text x="68" y="224"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          Cloudflare DNS
        </text>
        <text x="56" y="241"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.dns}
        </text>
      </g>
    </g>

    <!-- ===== ORACLE CLOUD CONTAINER ===== -->
    <g>
      <rect x="340" y="88" width="385" height="252" rx="12"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <rect x="340" y="88" width="385" height="5" rx="2.5"
        fill="var(--color-tertiary)" />
      <text x="532" y="118" text-anchor="middle"
        fill="var(--color-on-surface-variant)" font-family="var(--font-label)" font-size="11" font-weight="700" letter-spacing="1.5">
        ORACLE CLOUD VPS
      </text>

      <!-- Caddy -->
      <g>
        <rect x="360" y="130" width="345" height="48" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="360" y="130" width="4" height="48" rx="2"
          fill="var(--color-outline)" />
        <circle cx="378" cy="149" r="3.5" fill="var(--color-outline)" opacity="0.6" />
        <text x="388" y="153"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          Caddy
        </text>
        <text x="376" y="169"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.reverseProxy}
        </text>
      </g>

      <!-- Internal arrow: Caddy → API Active -->
      <line x1="443" y1="178" x2="443" y2="193"
        stroke="var(--color-outline)" stroke-width="1" marker-end="url(#arrow)" />

      <!-- Internal arrow: Caddy → API Standby (dashed) -->
      <line x1="622" y1="178" x2="622" y2="193"
        stroke="var(--color-outline-variant)" stroke-width="1" stroke-dasharray="3,2" marker-end="url(#arrow-muted)" />

      <!-- API Active -->
      <g>
        <rect x="360" y="198" width="165" height="64" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="360" y="198" width="4" height="64" rx="2"
          fill="var(--color-tertiary)" />
        <circle cx="378" cy="218" r="3.5" fill="var(--color-tertiary)" opacity="0.6" />
        <text x="388" y="222"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          ASP.NET Core
        </text>
        <text x="376" y="238"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          Backend API
        </text>
        <!-- Active badge -->
        <rect x="376" y="244" width="52" height="14" rx="7"
          fill="var(--color-primary)" opacity="0.15" />
        <text x="402" y="254" text-anchor="middle"
          fill="var(--color-primary)" font-family="var(--font-label)" font-size="9" font-weight="700">
          {t.active}
        </text>
      </g>

      <!-- API Standby (faded, dashed) -->
      <g opacity="0.5">
        <rect x="540" y="198" width="165" height="64" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="1" stroke-dasharray="4,3" />
        <rect x="540" y="198" width="4" height="64" rx="2"
          fill="var(--color-tertiary)" />
        <circle cx="558" cy="218" r="3.5" fill="var(--color-tertiary)" opacity="0.6" />
        <text x="568" y="222"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          ASP.NET Core
        </text>
        <text x="556" y="238"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          Backend API
        </text>
        <!-- Standby badge -->
        <rect x="556" y="244" width="58" height="14" rx="7"
          fill="var(--color-outline-variant)" opacity="0.3" />
        <text x="585" y="254" text-anchor="middle"
          fill="var(--color-on-surface-variant)" font-family="var(--font-label)" font-size="9" font-weight="700">
          {t.standby}
        </text>
      </g>

      <!-- Temporal (planned, faded) -->
      <g opacity="0.4">
        <rect x="360" y="278" width="345" height="48" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="1" stroke-dasharray="4,3" />
        <rect x="360" y="278" width="4" height="48" rx="2"
          fill="var(--color-tertiary)" />
        <circle cx="378" cy="297" r="3.5" fill="var(--color-tertiary)" opacity="0.6" />
        <text x="388" y="301"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          Temporal
        </text>
        <text x="376" y="317"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.backgroundJobs}
        </text>
        <!-- v4 badge -->
        <rect x="672" y="291" width="22" height="14" rx="7"
          fill="var(--color-outline-variant)" opacity="0.3" />
        <text x="683" y="301" text-anchor="middle"
          fill="var(--color-on-surface-variant)" font-family="var(--font-label)" font-size="9" font-weight="700">
          v4
        </text>
      </g>
    </g>

    <!-- ===== SUPABASE CONTAINER ===== -->
    <g>
      <rect x="775" y="88" width="270" height="252" rx="12"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <rect x="775" y="88" width="270" height="5" rx="2.5"
        fill="var(--color-on-surface-variant)" />
      <text x="910" y="118" text-anchor="middle"
        fill="var(--color-on-surface-variant)" font-family="var(--font-label)" font-size="11" font-weight="700" letter-spacing="1.5">
        SUPABASE
      </text>

      <!-- PostgreSQL -->
      <g>
        <rect x="795" y="135" width="230" height="50" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="795" y="135" width="4" height="50" rx="2"
          fill="var(--color-on-surface-variant)" />
        <circle cx="813" cy="155" r="3.5" fill="var(--color-on-surface-variant)" opacity="0.6" />
        <text x="823" y="159"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          PostgreSQL
        </text>
        <text x="811" y="176"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.database}
        </text>
      </g>

      <!-- Auth -->
      <g>
        <rect x="795" y="200" width="230" height="50" rx="8"
          fill="var(--color-surface-container-high)" stroke="var(--color-outline-variant)" stroke-width="0.5" />
        <rect x="795" y="200" width="4" height="50" rx="2"
          fill="var(--color-on-surface-variant)" />
        <circle cx="813" cy="220" r="3.5" fill="var(--color-on-surface-variant)" opacity="0.6" />
        <text x="823" y="224"
          fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
          Supabase Auth
        </text>
        <text x="811" y="241"
          fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
          {t.authentication} (JWT)
        </text>
      </g>
    </g>

    <!-- ===== MAIN ARROWS ===== -->

    <!-- Cloudflare → Oracle Cloud -->
    <line x1="293" y1="195" x2="333" y2="195"
      stroke="var(--color-outline)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- Oracle Cloud → Supabase -->
    <line x1="728" y1="195" x2="768" y2="195"
      stroke="var(--color-outline)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- ===== EXTERNAL SERVICES ===== -->

    <!-- Arrow: Oracle Cloud → Slack -->
    <line x1="467" y1="343" x2="467" y2="393"
      stroke="var(--color-outline)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- Arrow: Oracle Cloud → Email -->
    <line x1="627" y1="343" x2="627" y2="393"
      stroke="var(--color-outline)" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- Slack -->
    <g>
      <rect x="395" y="400" width="145" height="48" rx="8"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <text x="467" y="421" text-anchor="middle"
        fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
        Slack
      </text>
      <text x="467" y="438" text-anchor="middle"
        fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="10">
        Webhook
      </text>
    </g>

    <!-- Email -->
    <g>
      <rect x="555" y="400" width="145" height="48" rx="8"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <text x="627" y="421" text-anchor="middle"
        fill="var(--color-on-surface)" font-family="var(--font-body)" font-size="13" font-weight="600">
        Brevo
      </text>
      <text x="627" y="438" text-anchor="middle"
        fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="10">
        Email (SMTP)
      </text>
    </g>

    <!-- ===== GITHUB ACTIONS CI/CD ===== -->
    <g>
      <rect x="20" y="490" width="1025" height="50" rx="12"
        fill="var(--color-surface-container)" stroke="var(--color-outline-variant)" stroke-width="1" />
      <rect x="20" y="490" width="1025" height="5" rx="2.5"
        fill="var(--color-outline)" />
      <circle cx="48" cy="521" r="3.5" fill="var(--color-outline)" opacity="0.6" />
      <text x="58" y="525"
        fill="var(--color-on-surface)" font-family="var(--font-headline)" font-size="14" font-weight="700">
        GitHub Actions
      </text>
      <text x="195" y="525"
        fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="12">
        {t.cicd}
      </text>
      <text x="1015" y="525" text-anchor="end"
        fill="var(--color-on-surface-variant)" font-family="var(--font-body)" font-size="11">
        {t.pipeline}
      </text>
    </g>
  </svg>
</div>
