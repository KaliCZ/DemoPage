          DNS
        </text>
        <text
          x="54"
          y="106"
          fill="var(--color-on-surface-variant)"
          font-family="var(--font-body)"
          font-size="11"
        >
          {t.dns}
        </text>
      </g>

      <!-- Static Site -->
      <g>
        <rect
          x="38"
          y="130"
          width="224"
          height="50"
          rx="8"
          fill="var(--color-surface-container-high)"
          stroke="var(--color-outline-variant)"
