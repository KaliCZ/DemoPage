        x="20"
        y="20"
        width="260"
        height="5"
        rx="2.5"
        fill="var(--color-primary)"></rect>
      <text
        x="150"
        y="50"
        text-anchor="middle"
        fill="var(--color-on-surface-variant)"
        font-family="var(--font-label)"
        font-size="11"
        font-weight="700"
        letter-spacing="1.5"
      >
        CLOUDFLARE
      </text>

      <!-- DNS -->
      <g>
        <rect
          x="38"
          y="65"
          width="224"
          height="50"
          rx="8"
          fill="var(--color-surface-container-high)"
          stroke="var(--color-outline-variant)"
          stroke-width="0.5"></rect>
        <rect
          x="38"
          y="65"
          width="4"
          height="50"
          rx="2"
          fill="var(--color-primary)"></rect>
        <circle
          cx="56"
          cy="85"
          r="3.5"
          fill="var(--color-primary)"
          opacity="0.6"></circle>
        <text
          x="66"
          y="89"
          fill="var(--color-on-surface)"
          font-family="var(--font-body)"
          font-size="13"
          font-weight="600"
