---
interface Props {
  isAdmin: boolean;
  t: Record<string, any>;
  f?: Record<string, any>;
}

const { isAdmin, t, f } = Astro.props;
---

<section id="offer-detail-section" class="hidden max-w-3xl mx-auto px-8 mb-16">
  <button
    id="back-to-list"
    type="button"
    class="flex items-center gap-2 text-sm font-label text-on-surface-variant hover:text-primary transition-colors mb-8 cursor-pointer"
  >
    <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_back</span>
    {t.list.back}
  </button>
  <div id="offer-detail" class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12"></div>

  {
    isAdmin ? (
      <div id="admin-controls" class="hidden mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
        <h3 class="font-headline text-lg font-bold text-on-surface mb-4">{t.list.updateStatus}</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <select
            id="status-select"
            class="px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
          >
            <option value="Submitted">{t.list.submitted}</option>
            <option value="InReview">{t.list.inReview}</option>
            <option value="LetsTalk">{t.list.accepted}</option>
            <option value="Declined">{t.list.declined}</option>
          </select>
          <textarea
            id="admin-notes-input"
            rows="2"
            placeholder={t.list.adminNotes}
            class="flex-1 px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y"
          />
          <button
            id="save-status"
            type="button"
            class="px-6 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer self-start"
          >
            {t.list.save}
          </button>
        </div>
      </div>
    ) : (
      <>
        <div id="edit-form-section" class="hidden mt-6">
          <form
            id="edit-form"
            novalidate
            class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12 space-y-6"
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="edit-companyName" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.companyName}
                </label>
                <input
                  type="text"
                  id="edit-companyName"
                  name="companyName"
                  required
                  maxlength="200"
                  placeholder={f.companyNamePlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
              <div>
                <label for="edit-contactName" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.contactName}
                </label>
                <input
                  type="text"
                  id="edit-contactName"
                  name="contactName"
                  required
                  maxlength="200"
                  placeholder={f.contactNamePlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="edit-contactEmail" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.contactEmail}
                </label>
                <input
                  type="email"
                  id="edit-contactEmail"
                  name="contactEmail"
                  required
                  maxlength="255"
                  placeholder={f.contactEmailPlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
              <div>
                <label for="edit-jobTitle" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.jobTitle}
                </label>
                <input
                  type="text"
                  id="edit-jobTitle"
                  name="jobTitle"
                  required
                  maxlength="200"
                  placeholder={f.jobTitlePlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
            </div>
            <div>
              <label for="edit-description" class="block text-sm font-label font-semibold text-on-surface mb-2">
                {f.description}
              </label>
              <textarea
                id="edit-description"
                name="description"
                required
                maxlength="5000"
                rows="5"
                placeholder={f.descriptionPlaceholder}
                class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
              />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="edit-salaryRange" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.salaryRange}
                </label>
                <input
                  type="text"
                  id="edit-salaryRange"
                  name="salaryRange"
                  maxlength="100"
                  placeholder={f.salaryRangePlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
              <div>
                <label for="edit-location" class="block text-sm font-label font-semibold text-on-surface mb-2">
                  {f.location}
                </label>
                <input
                  type="text"
                  id="edit-location"
                  name="location"
                  maxlength="200"
                  placeholder={f.locationPlaceholder}
                  class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                />
              </div>
            </div>
            <div class="flex items-center gap-3">
              <input
                type="checkbox"
                id="edit-isRemote"
                name="isRemote"
                class="w-5 h-5 rounded border-outline-variant/20 text-primary focus:ring-primary/30 accent-primary"
              />
              <label for="edit-isRemote" class="text-sm font-label font-semibold text-on-surface">
                {f.isRemote}
              </label>
            </div>
            <div>
              <label for="edit-additionalNotes" class="block text-sm font-label font-semibold text-on-surface mb-2">
                {f.additionalNotes}
              </label>
              <textarea
                id="edit-additionalNotes"
                name="additionalNotes"
                maxlength="2000"
                rows="3"
                placeholder={f.additionalNotesPlaceholder}
                class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
              />
            </div>
            <div id="edit-error" class="hidden text-error text-sm font-body" />
            <div class="flex gap-4">
              <button
                type="submit"
                class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer"
              >
                {t.list.editSave}
              </button>
              <button
                type="button"
                id="edit-discard"
                class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-surface-container-high text-on-surface hover:bg-surface-container-highest transition-colors cursor-pointer"
              >
                {t.list.editCancel}
              </button>
            </div>
          </form>
        </div>

        <div id="user-actions" class="hidden mt-6 flex gap-4">
          <button
            id="edit-btn"
            type="button"
            class="hidden flex items-center gap-2 px-6 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer"
          >
            <span class="material-symbols-outlined text-lg" aria-hidden="true">
              edit
            </span>
            {t.list.edit}
          </button>
          <button
            id="cancel-btn"
            type="button"
            class="hidden flex items-center gap-2 px-6 py-2 rounded-xl text-sm font-semibold font-label bg-error text-on-primary hover:bg-error/90 transition-colors cursor-pointer"
          >
            <span class="material-symbols-outlined text-lg" aria-hidden="true">
              cancel
            </span>
            {t.list.cancel}
          </button>
        </div>

        <div id="cancel-controls" class="hidden mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
          <h3 class="font-headline text-lg font-bold text-on-surface mb-4">{t.list.cancel}</h3>
          <p class="text-sm text-on-surface-variant font-body mb-4">{t.list.cancelConfirm}</p>
          <textarea
            id="cancel-reason"
            rows="2"
            placeholder={t.list.cancelReason}
            class="w-full px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y mb-4"
          />
          <button
            id="confirm-cancel"
            type="button"
            class="px-6 py-2 rounded-xl text-sm font-semibold font-label bg-error text-on-primary hover:bg-error/90 transition-colors cursor-pointer"
          >
            {t.list.cancelButton}
          </button>
        </div>
      </>
    )
  }

  <!-- Comments -->
  <div id="comments-section" class="mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
    <h3 class="font-headline text-lg font-bold text-on-surface mb-4">
      <span class="material-symbols-outlined text-lg align-middle mr-1" aria-hidden="true">chat</span>
      {t.list.comments}
    </h3>
    <div id="comments-list" class="space-y-4 mb-4"></div>
    <div class="flex gap-3">
      <textarea
        id="comment-input"
        rows="2"
        placeholder={t.list.commentPlaceholder}
        class="flex-1 px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y"
      ></textarea>
      <button
        id="send-comment"
        type="button"
        class="px-5 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer self-end"
      >
        {t.list.commentSend}
      </button>
    </div>
  </div>

  <!-- Activity log -->
  <div id="history-section" class="mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
    <h3 class="font-headline text-lg font-bold text-on-surface mb-4">
      <span class="material-symbols-outlined text-lg align-middle mr-1" aria-hidden="true">history</span>
      {t.list.history}
    </h3>
    <div id="history-list" class="space-y-3"></div>
  </div>
</section>
