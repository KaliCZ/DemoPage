---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import BlogRssLink from "./BlogRssLink.astro";
import BlogReactions from "./blog/BlogReactions.vue";
import BlogComments from "./blog/BlogComments.vue";
import BlogReadStatus from "./blog/BlogReadStatus.vue";
import { locales, localePath, type Locale } from "../i18n/utils";
import { postLocales, type BlogPostMetadata } from "../blog/types";
import enBlog from "../i18n/en/blog.json";
import csBlog from "../i18n/cs/blog.json";

interface Props {
  metadata: BlogPostMetadata;
  lang: Locale;
}

const { metadata, lang } = Astro.props;
const t = lang === "cs" ? csBlog : enBlog;

// The slug is the last path segment — identical for /blog/x and /cs/blog/x —
// and keys the post's reaction and comment streams in the backend.
const slug = Astro.url.pathname.replace(/\/$/, "").split("/").pop()!;
const pagePath = `blog/${slug}`;

// blogPostStaticPaths only builds routes for declared languages, so the variant exists.
const variant = metadata.variants[lang]!;
const availableLocales = postLocales(metadata);
// The language picker jumps to the translated post, or to the blog index when no translation exists.
const langUrls = Object.fromEntries(
  locales.map((locale) => [locale, localePath(locale, availableLocales.includes(locale) ? pagePath : "blog")]),
) as Record<Locale, string>;

const pubDate = new Date(metadata.pubDate);
const updatedDate = metadata.updatedDate ? new Date(metadata.updatedDate) : undefined;
const dateLocale = lang === "cs" ? "cs-CZ" : "en-US";
const formatDate = (date: Date) => date.toLocaleDateString(dateLocale, { year: "numeric", month: "long", day: "numeric" });

const apiUrl = import.meta.env.PUBLIC_API_URL || "";

// Reading estimate from the rendered body (only the active language's slot renders); code blocks don't count.
const contentHtml = await Astro.slots.render("default");
const wordCount = contentHtml
  .replace(/<pre[\s\S]*?<\/pre>/gi, " ")
  .replace(/<[^>]*>/g, " ")
  .split(/\s+/)
  .filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));
const readingTimeLabel = t.post.readingTime.replace("{min}", String(readingMinutes));
---

<Layout
  title={`${variant.title} | kalandra.tech`}
  description={variant.summary}
  activePage="blog"
  lang={lang}
  pagePath={pagePath}
  alternateLocales={availableLocales}
  langUrls={langUrls}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    {metadata.tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <article class="max-w-6xl mx-auto px-4 md:px-8">
    <header class="mb-10">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <a
          href={localePath(lang, "blog")}
          class="inline-flex items-center gap-1 text-sm font-label text-on-surface-variant hover:text-primary transition-colors"
        >
          <Icon name="material-symbols:arrow-back" class="size-4" aria-hidden="true" />
          {t.post.backToBlog}
        </a>
        <BlogRssLink label={t.rss.label} title={t.rss.title} />
      </div>
      <h1 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter leading-tight mb-4">
        {variant.title}
      </h1>
      <p class="font-label text-sm text-on-surface-variant">
        <time datetime={metadata.pubDate}>{formatDate(pubDate)}</time>
        {" · "}
        <span>{readingTimeLabel}</span>
        {
          updatedDate && metadata.updatedDate && (
            <span>
              {" · "}
              {t.post.updatedOn} <time datetime={metadata.updatedDate}>{formatDate(updatedDate)}</time>
            </span>
          )
        }
      </p>
      <!-- Public view count for everyone; the island adds the reader's own "read N times" when signed in. -->
      <p class="font-label text-sm text-on-surface-variant mt-1">
        <BlogReadStatus client:idle apiUrl={apiUrl} slug={slug} t={t.readState} />
      </p>
      {
        metadata.tags.length > 0 && (
          <ul class="flex flex-wrap gap-2 mt-4" role="list">
            {metadata.tags.map((tag) => (
              <li class="px-3 py-1 rounded-full bg-surface-container-low border border-outline-variant/30 text-xs font-label text-on-surface-variant">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose prose-lg max-w-none font-body">
      <Fragment set:html={contentHtml} />
    </div>

    <footer class="mt-16 pt-10 border-t border-outline-variant/30">
      <div class="space-y-14">
        <div>
          <BlogReactions client:idle apiUrl={apiUrl} slug={slug} t={t.reactions} />
        </div>
        <BlogComments client:idle apiUrl={apiUrl} slug={slug} lang={lang} t={t.comments} />
      </div>
      <!-- The comments island hydrates after paint, so this auth-gated CTA stays static markup. -->
      <section
        id="blog-signin-cta"
        class="signed-out-only mt-20 bg-surface-container rounded-2xl border border-outline-variant/40 p-6 md:p-8 text-center"
      >
        <Icon name="material-symbols:forum" class="size-9 text-primary mb-3 mx-auto block" aria-hidden="true" />
        <h2 class="font-headline text-xl font-bold text-on-surface mb-2">{t.signInCta.title}</h2>
        <p class="font-body text-sm text-on-surface-variant mb-5">{t.signInCta.description}</p>
        <button
          id="blog-signin-cta-button"
          type="button"
          class="px-5 py-2.5 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer"
        >
          {t.signInCta.button}
        </button>
      </section>
    </footer>
  </article>

  <script>
    import { openAuthDialog } from "../lib/auth";

    document.getElementById("blog-signin-cta-button")?.addEventListener("click", openAuthDialog);

    window.addEventListener("auth-change", (event) => {
      const signedIn = !!(event as CustomEvent).detail?.user;
      document.getElementById("blog-signin-cta")?.classList.toggle("hidden", signedIn);
    });
  </script>
</Layout>
