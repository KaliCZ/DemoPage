---
/**
 * Pre-paint theme detection.
 *
 * Renders an inline blocking <script> + global <style> that resolves the
 * visitor's preferred color scheme before the browser paints the first frame.
 * Without this, every navigation would briefly render in light mode (the
 * default) before the JS-driven theme toggle had a chance to apply the `dark`
 * class — visible as a "white flash" on dark-mode users.
 *
 * Mechanism:
 *   1. The inline script reads `localStorage.theme`, falling back to the
 *      system `prefers-color-scheme` media query, and adds the `dark` class
 *      to <html> before the parser moves on.
 *   2. The global CSS rules use that class to swap the theme toggle's sun /
 *      moon icons via display, instead of relying on JS to set inline styles
 *      after the document loads. This avoids a second flash where the wrong
 *      icon would render briefly before `updateToggleIcons()` ran.
 *
 * MUST be rendered inline in <head> and MUST stay an inline blocking script —
 * see AuthPrePaint.astro for the same reasoning.
 */
---

<script is:inline>
  (function () {
    var theme = localStorage.getItem('theme');
    if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  })();
</script>

<style is:global>
  /* Theme toggle icons: pure-CSS swap keyed off the `dark` class set above,
     so the correct icon paints immediately on first frame instead of being
     toggled by an end-of-body script. */
  html:not(.dark) .dark-visible { display: none !important; }
  html.dark .dark-hidden { display: none !important; }
  html.dark .dark-visible { display: inline-block !important; }
</style>
