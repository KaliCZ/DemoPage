---
/**
 * Pre-paint auth state detection.
 *
 * Renders an inline blocking <script> + global <style> that resolves the
 * visitor's signed-in / signed-out state from supabase's localStorage session
 * before the browser paints the first frame. Without this, every navigation
 * would briefly show the signed-out UI (sign-in button, login prompt, empty
 * profile chip) until the bundled supabase JS module hydrated and resolved
 * `getSession()` — visible as a flash and a layout shift in the header.
 *
 * Mechanism:
 *   1. The inline script reads the `sb-<project-ref>-auth-token` key from
 *      localStorage and parses the persisted session JSON.
 *   2. It tags <html> with `auth-known-in` or `auth-known-out`, and stashes
 *      the user's display name + avatar + admin flag on `window.__authPrefill`
 *      for the post-nav prefill script in Layout.astro to apply.
 *   3. The global CSS rules use those classes (with !important so they win
 *      over Tailwind's `hidden` utility) to show the correct header element
 *      and hide the wrong one before first paint.
 *   4. Pages can opt into the same mechanism for their own auth-gated content
 *      via the generic `.signed-in-only` / `.signed-out-only` helper classes.
 *   5. Once `supabase.auth.getSession()` resolves in Layout.astro's module
 *      script, the `auth-known-*` class is removed so JS retains control of
 *      sign-in / sign-out transitions during the page's lifetime.
 *
 * MUST be rendered inline in <head> and MUST stay an inline blocking script —
 * moving it to an external file would force a network round-trip on every
 * navigation and reintroduce the flash. See PR #26 for context.
 */
---

<script is:inline>
  (function () {
    try {
      var session = null;
      for (var i = 0; i < localStorage.length; i++) {
        var k = localStorage.key(i);
        if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') === k.length - 11) {
          var v = localStorage.getItem(k);
          if (v && v.length > 2) { try { session = JSON.parse(v); } catch (_) {} break; }
        }
      }
      if (session && session.user) {
        var u = session.user;
        var meta = u.user_metadata || {};
        window.__authPrefill = {
          name: meta.full_name || (u.email ? u.email.split('@')[0] : 'User'),
          avatar: meta.avatar_url || '',
          isAdmin: !!(u.app_metadata && Array.isArray(u.app_metadata.roles) && u.app_metadata.roles.indexOf('admin') !== -1),
        };
        document.documentElement.classList.add('auth-known-in');
      } else {
        document.documentElement.classList.add('auth-known-out');
      }
    } catch (e) {
      document.documentElement.classList.add('auth-known-out');
    }
  })();
</script>

<style is:global>
  /* Header auth slot — hide the wrong element before first paint. !important
     wins over the Tailwind `hidden` class still present on the profile chip. */
  html.auth-known-in #auth-sign-in-desktop,
  html.auth-known-in #auth-sign-in-mobile { display: none !important; }
  html.auth-known-in #auth-profile-desktop { display: block !important; }
  html.auth-known-in #auth-profile-mobile { display: block !important; }
  html.auth-known-out #auth-profile-desktop,
  html.auth-known-out #auth-profile-mobile { display: none !important; }

  /* Generic helpers any page can use to gate content on auth state pre-paint.
     Add `signed-in-only` to elements that should only be visible when signed
     in, and `signed-out-only` to elements that should only be visible when
     signed out. */
  html.auth-known-in .signed-out-only { display: none !important; }
  html.auth-known-out .signed-in-only { display: none !important; }
  html.auth-known-in .signed-in-only { display: block !important; }
</style>
