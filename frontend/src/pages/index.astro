---
import Layout from '../layouts/Layout.astro';
---

<Layout title="kalandra.tech — Pavel Kalandra" activePage="home">

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-8 mb-24 lg:mb-40">
    <div class="max-w-3xl">
      <span class="font-label text-tertiary uppercase tracking-widest text-sm mb-4 block">Welcome</span>
      <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.1] mb-8">
        Hi, I'm <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-tertiary">Pavel Kalandra.</span>
      </h1>
      <p class="font-body text-xl md:text-2xl text-on-surface-variant leading-relaxed mb-12">
        Software engineer and engineering leader based in Prague.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">

      <!-- About Me card -->
      <a href="/about" class="group bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-primary text-2xl">person</span>
          <h2 class="font-headline text-2xl font-bold group-hover:text-primary transition-colors">About Me</h2>
        </div>
        <p class="text-on-surface-variant leading-relaxed mb-6">
          What drives me as an engineer.
        </p>
        <span class="font-label text-sm uppercase tracking-widest text-primary flex items-center gap-1">
          Read more <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </span>
      </a>

      <!-- Project card -->
      <a href="/project" class="group bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-tertiary/30 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-tertiary text-2xl">rocket_launch</span>
          <h2 class="font-headline text-2xl font-bold group-hover:text-tertiary transition-colors">Project</h2>
        </div>
        <p class="text-on-surface-variant leading-relaxed mb-6">
          From static page to advanced features. Follow the roadmap.
        </p>
        <span class="font-label text-sm uppercase tracking-widest text-tertiary flex items-center gap-1">
          View roadmap <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </span>
      </a>

    </div>
  </section>

  <!-- What's here section -->
  <section class="bg-surface-container-low py-24 border-y border-on-surface/5">
    <div class="max-w-7xl mx-auto px-8">
      <div class="max-w-2xl">
        <h3 class="font-headline text-3xl font-extrabold mb-6 tracking-tight">What is this page?</h3>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
          <strong class="text-on-surface">kalandra.tech</strong> is my personal website, but it's also an experiment.
          I'm building it in public — every version, every architectural decision, every deployment pipeline choice is documented.
        </p>
        <p class="text-on-surface-variant text-lg leading-relaxed">
          More projects are coming in the future. For now, the only project here is
          <a href="/project" class="text-primary hover:underline">the meta-project of building this very site</a>.
          Stay tuned.
        </p>
      </div>
    </div>
  </section>

</Layout>
