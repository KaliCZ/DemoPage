---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Me | Pavel Kalandra — kalandra.tech" activePage="about">

  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-8 mb-24 lg:mb-40">
    <div class="flex flex-col md:flex-row items-end gap-12">
      <div class="w-full md:w-2/3">
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none mb-8">
          Pavel Kalandra
        </h1>
        <div class="flex items-center gap-2 mb-8 text-on-surface-variant font-label text-md">
          <span class="material-symbols-outlined text-tertiary">location_on</span>
          Prague, Czech Republic
        </div>
        <p class="font-body text-xl md:text-2xl text-on-surface-variant max-w-2xl leading-relaxed mb-10">
          Software engineer and engineering leader dedicated to building resilient systems and high-performing teams.
        </p>
        <div class="flex gap-6">
          <a
            class="flex items-center gap-2 font-label text-sm uppercase tracking-widest hover:text-primary transition-colors"
            href="https://github.com/kalicz"
            target="_blank"
            rel="noopener"
            title="GitHub — kalicz"
            aria-label="GitHub profile"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            GitHub
          </a>
          <a
            class="flex items-center gap-2 font-label text-sm uppercase tracking-widest hover:text-primary transition-colors"
            href="https://www.linkedin.com/in/pavelkalandra/"
            target="_blank"
            rel="noopener"
            title="LinkedIn — Pavel Kalandra"
            aria-label="LinkedIn profile"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
      <!-- Portrait -->
      <div class="w-full md:w-1/3 aspect-square rounded-xl overflow-hidden border border-outline-variant/20">
        <img
          src="/images/pavel-portrait.jpg"
          alt="Pavel Kalandra"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Manifesto Section -->
  <section class="bg-surface-container-low py-24 mb-24 lg:mb-40 relative overflow-hidden border-y border-on-surface/5">
    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-[100px] -mr-32 -mt-32"></div>
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left Column -->
        <div>
          <h2 class="font-headline text-4xl font-extrabold mb-8 tracking-tight">My Manifesto</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed mb-12">
            Designing systems that don't just work today, but evolve gracefully over time.
          </p>
          <ul class="space-y-8">
            <li class="flex gap-4">
              <span class="material-symbols-outlined text-primary text-3xl">architecture</span>
              <div>
                <h5 class="font-bold text-xl mb-2">Resilient Architecture</h5>
                <p class="text-on-surface-variant leading-relaxed">Systems that evolve gracefully as business needs shift.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="material-symbols-outlined text-tertiary text-3xl">groups</span>
              <div>
                <h5 class="font-bold text-xl mb-2">Empowered Teams</h5>
                <p class="text-on-surface-variant leading-relaxed">Autonomous cultures where every engineer has ownership and a path to mastery.</p>
              </div>
            </li>
          </ul>
        </div>
        <!-- Right Column (Expandable sections) -->
        <div class="flex flex-col justify-center">
          <div class="space-y-4">

            <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm">
              <summary class="p-6 cursor-pointer font-label text-base text-primary flex justify-between items-center select-none">
                <span>Allow yourself to scale</span>
                <span class="material-symbols-outlined text-sm transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
                Software shouldn't be hard. Every piece of software requires maintenance and learning. If it doesn't make your life easier, build it different. Or don't build it at all. Don't get stuck in maintenance mode. Use your time for building value.
              </div>
            </details>

            <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm">
              <summary class="p-6 cursor-pointer font-label text-base text-tertiary flex justify-between items-center select-none">
                <span>Be happy about your work</span>
                <span class="material-symbols-outlined text-sm transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
                Most engineers do this job because they love building. Give them some free time and just watch how they make your software grow. Motivating engineers shouldn't be difficult.
              </div>
            </details>

            <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm">
              <summary class="p-6 cursor-pointer font-label text-base text-secondary flex justify-between items-center select-none">
                <span>Focus on DX</span>
                <span class="material-symbols-outlined text-sm transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
                By applying the two points above, you get a simple implication. Fix what's bothering the engineers and they will make your product better in return. Everybody wins. Everybody's happy.
              </div>
            </details>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Journey Section -->
  <section class="max-w-7xl mx-auto px-8 mb-40">
    <div class="text-center mb-24">
      <span class="font-label text-secondary uppercase tracking-widest text-sm mb-4 block">The Path</span>
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tighter">Career Journey</h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical Line -->
      <div class="absolute left-1/2 -translate-x-1/2 w-px h-full bg-outline-variant/30 hidden md:block"></div>

      <div class="space-y-24 md:space-y-0">

        <!-- CTO at tickadoo (Right) -->
        <div class="md:flex justify-end items-center w-full md:mb-24">
          <div class="hidden md:block w-1/2"></div>
          <div class="relative md:w-1/2 md:pl-16">
            <div class="absolute -left-2 md:-left-1.5 top-0 w-4 h-4 rounded-full bg-primary shadow-[0_0_15px_rgba(72,88,171,0.3)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">Jun 2025 — Present</span>
              <h3 class="font-headline text-2xl font-bold mt-2">CTO</h3>
              <p class="font-label text-on-surface-variant mb-4">tickadoo</p>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">Responsible for overall system architecture, feature design and ways of working.</p>
            </div>
          </div>
        </div>

        <!-- Staff Software Engineer at Outreach (Left) -->
        <div class="md:flex justify-start items-center w-full md:mb-24">
          <div class="relative md:w-1/2 md:pr-16 md:text-right">
            <div class="absolute -right-2 top-0 w-4 h-4 rounded-full bg-tertiary shadow-[0_0_15px_rgba(0,106,106,0.2)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-tertiary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">Feb 2025 — Aug 2025</span>
              <h3 class="font-headline text-2xl font-bold mt-2">Staff Software Engineer</h3>
              <p class="font-label text-on-surface-variant mb-4">Outreach</p>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">Owning the product surface, coordinating larger changes across the R&D organization. Left for a great opportunity as CTO at tickadoo.</p>
            </div>
          </div>
          <div class="hidden md:block w-1/2"></div>
        </div>

        <!-- Tribe Lead at Rossum (Right) -->
        <div class="md:flex justify-end items-center w-full md:mb-24">
          <div class="hidden md:block w-1/2"></div>
          <div class="relative md:w-1/2 md:pl-16">
            <div class="absolute -left-2 md:-left-1.5 top-0 w-4 h-4 rounded-full bg-primary shadow-[0_0_15px_rgba(72,88,171,0.3)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">Apr 2024 — Jan 2025</span>
              <h3 class="font-headline text-2xl font-bold mt-2">Tribe Lead</h3>
              <p class="font-label text-on-surface-variant mb-4">Rossum</p>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">Led one-third of engineering, restructuring into product-focused teams and coaching new leaders.</p>
            </div>
          </div>
        </div>

        <!-- Mews (Left) — combined -->
        <div class="md:flex justify-start items-center w-full md:mb-24">
          <div class="relative md:w-1/2 md:pr-16 md:text-right">
            <div class="absolute -right-2 top-0 w-4 h-4 rounded-full bg-tertiary shadow-[0_0_15px_rgba(0,106,106,0.2)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-tertiary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">Mar 2018 — Mar 2024</span>
              <h3 class="font-headline text-2xl font-bold mt-2">Mews</h3>
              <p class="font-label text-on-surface-variant mb-6">6 years across 3 roles</p>

              <div class="space-y-6 text-left">
                <div class="border-l-2 border-primary/30 pl-4">
                  <p class="font-label text-xs text-tertiary uppercase tracking-widest">Apr 2023 — Mar 2024</p>
                  <p class="font-bold mt-1">Staff Engineer</p>
                  <p class="font-body text-on-surface-variant text-sm leading-relaxed mt-1">Single-handedly drove a DX initiative that cut local startup time by 61%, saved 137 GB of database bloat, and overhauled the FuncSharp library — improving hot-path performance and adding stronger type-safety to prevent entire categories of bugs at compile time. Championed culture changes across backend engineering.</p>
                </div>
                <div class="border-l-2 border-primary/30 pl-4">
                  <p class="font-label text-xs text-tertiary uppercase tracking-widest">Jan 2019 — Apr 2023</p>
                  <p class="font-bold mt-1">Engineering Manager, Finance</p>
                  <p class="font-body text-on-surface-variant text-sm leading-relaxed mt-1">Led cross-functional team overseeing billing, reporting, and fiscal compliance. Transitioned to multi-tax systems for global expansion.</p>
                </div>
                <div class="border-l-2 border-primary/30 pl-4">
                  <p class="font-label text-xs text-tertiary uppercase tracking-widest">Mar 2018 — Dec 2018</p>
                  <p class="font-bold mt-1">Back End Developer</p>
                </div>
              </div>
            </div>
          </div>
          <div class="hidden md:block w-1/2"></div>
        </div>

        <!-- Software Developer at ZENTITY (Right) -->
        <div class="md:flex justify-end items-center w-full md:mb-24">
          <div class="hidden md:block w-1/2"></div>
          <div class="relative md:w-1/2 md:pl-16">
            <div class="absolute -left-2 md:-left-1.5 top-0 w-4 h-4 rounded-full bg-primary shadow-[0_0_15px_rgba(72,88,171,0.3)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-primary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">Apr 2016 — Feb 2018</span>
              <h3 class="font-headline text-2xl font-bold mt-2">Software Developer</h3>
              <p class="font-label text-on-surface-variant mb-4">ZENTITY a.s.</p>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">Managed ASP.NET web application; later migrated from SQL reporting to custom d3.js/Vue.js reporting.</p>
            </div>
          </div>
        </div>

        <!-- Earlier career (Left) -->
        <div class="md:flex justify-start items-center w-full">
          <div class="relative md:w-1/2 md:pr-16 md:text-right">
            <div class="absolute -right-2 top-0 w-4 h-4 rounded-full bg-tertiary shadow-[0_0_15px_rgba(0,106,106,0.2)] z-10 hidden md:block"></div>
            <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 hover:border-tertiary/30 transition-all duration-300 shadow-sm hover:shadow-md">
              <span class="font-label text-tertiary text-xs uppercase tracking-widest">2014 — 2017</span>
              <h3 class="font-headline text-2xl font-bold mt-2">Early Career</h3>
              <p class="font-label text-on-surface-variant mb-4">CN Group CZ &middot; Lynax</p>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">Started as a C# intern during university, progressing through WPF development and CodedUI testing. Built desktop applications and tablet interfaces.</p>
            </div>
          </div>
          <div class="hidden md:block w-1/2"></div>
        </div>

      </div>
    </div>
  </section>

</Layout>
