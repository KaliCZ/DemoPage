---
import { Code } from "astro:components";
import BlogPostLayout from "../../../components/BlogPostLayout.astro";
import { blogPostStaticPaths, type BlogPostMetadata } from "../../../blog/types";
import { defaultLocale, localePath, type Locale } from "../../../i18n/utils";

export const metadata: BlogPostMetadata = {
  variants: {
    en: {
      title: "Zero-Code Validations in Your .NET API",
      summary:
        "How swapping primitive strings and ints for Kalicz.StrongTypes turned request validation into something the JSON deserializer and the compiler do for me — less code, honest signatures, and far fewer edge cases to test.",
    },
    cs: {
      title: "Validace v .NET API bez jediného řádku kódu",
      summary:
        "Jak výměna primitivních stringů a intů za Kalicz.StrongTypes proměnila validaci requestů v práci pro JSON deserializér a kompilátor — méně kódu, upřímné signatury a mnohem méně hraničních případů k testování.",
    },
  },
  pubDate: "2026-07-04",
  tags: ["dotnet", "csharp", "strong-types", "api-design", "validations"],
};

export const getStaticPaths = () => blogPostStaticPaths(metadata);

const lang = (Astro.params.lang ?? defaultLocale) as Locale;

const codeThemes = { light: "github-light", dark: "github-dark" } as const;

const beforeSnippet = `public record CreateOrderRequest(
    [EmailAddress] string CustomerEmail,
    string ProductCode,
    [Range(1, int.MaxValue)] int Quantity);

[HttpPost]
[ProducesResponseType<OrderResponse>(StatusCodes.Status200OK)]
[ProducesResponseType<ValidationProblemDetails>(StatusCodes.Status400BadRequest)]
public async Task<ActionResult<OrderResponse>> Create(CreateOrderRequest request)
{
    // We need to parse, because data annotations don't change the type.
    if (!MailAddress.TryCreate(request.CustomerEmail, out _))
        return ValidationProblem("Customer email is not valid.");

    try
    {
        var order = await orders.PlaceAsync(request.CustomerEmail, request.ProductCode, request.Quantity);
        return Ok(OrderResponse.From(order));
    }
    catch (UnknownProductException) // Could be checked explicitly via a separate method
    {
        return ValidationProblem("No product matches that code.");
    }
    catch (OutOfStockException)
    {
        return ValidationProblem("Not enough stock to fill the order.");
    }
}`;

const beforeServiceSnippet = `public async Task<Order> PlaceAsync(string customerEmail, string productCode, int quantity)
{
    // The controller already checked all this. But PlaceAsync takes plain strings
    // and an int, so it can be called from anywhere — and it can't trust that it was.
    if (string.IsNullOrWhiteSpace(productCode))
        throw new ArgumentException("Product code is required.", nameof(productCode));
    if (quantity <= 0)
        throw new ArgumentOutOfRangeException(nameof(quantity), "Quantity must be positive.");

    if (!await catalog.ContainsAsync(productCode))
        throw new UnknownProductException(productCode);

    // ...the same guards as the API, one layer down — then the real work.
}`;

const afterSnippet = `public record CreateOrderRequest(
    Email CustomerEmail,
    NonEmptyString ProductCode,
    Positive<int> Quantity);

[HttpPost]
[ProducesResponseType<OrderResponse>(StatusCodes.Status200OK)]
[ProducesResponseType<ValidationProblemDetails>(StatusCodes.Status400BadRequest)]
public async Task<ActionResult<OrderResponse>> Create(CreateOrderRequest request)
{
    // An invalid payload never reaches this line: the built-in System.Text.Json
    // converters already rejected it with a 400, naming the offending field.
    var result = await orders.PlaceAsync(request.CustomerEmail, request.ProductCode, request.Quantity);

    if (result.Error is { } error)
        return error switch
        {
            PlaceOrderError.UnknownProduct => FieldProblem(nameof(request.ProductCode), "No product matches that code."),
            PlaceOrderError.OutOfStock => FieldProblem(nameof(request.Quantity), "Not enough stock to fill the order."),
        };

    return Ok(OrderResponse.From(result.Success!));
}

// Keys the 400 to a request field, so it reads like the deserializer's own errors.
private ActionResult FieldProblem(string field, string message)
{
    ModelState.AddModelError(field, message);
    return ValidationProblem(ModelState);
}`;

const openApiSnippet = `{
  "customerEmail": { "type": "string", "format": "email" },   // Email
  "productCode":   { "type": "string", "minLength": 1 },      // NonEmptyString
  "quantity":      { "type": "integer", "minimum": 1 }        // Positive<int>
}`;

const openApiSetupSnippet = `// Program.cs — install Kalicz.StrongTypes.OpenApi.Swashbuckle, then one call
builder.Services.AddSwaggerGen(options => options.AddStrongTypes());`;

const signatureSnippet = `// Before: every caller re-checks, every reader wonders.
Task<Order> PlaceAsync(string email, string code, int quantity);

// After: the signature is the contract.
Task<Order> PlaceAsync(Email email, NonEmptyString code, Positive<int> quantity);`;

const resultSnippet = `public async Task<Result<Order, PlaceOrderError>> PlaceAsync(Email email, NonEmptyString code, Positive<int> quantity)
{
    if (!await catalog.ContainsAsync(code))
        return PlaceOrderError.UnknownProduct;

    if (!await inventory.HasStockAsync(code, quantity))
        return PlaceOrderError.OutOfStock;

    return new Order(email, code, quantity);
}`;

const entitySnippet = `public sealed class Order
{
    public Guid Id { get; init; }
    public Email CustomerEmail { get; init; }
    public NonEmptyString ProductCode { get; init; }
    public Positive<int> Quantity { get; init; }
}

// Program.cs — StrongTypes registration for db context.
services.AddDbContext<ShopDbContext>(options => options
    .UseNpgsql(connectionString)
    .UseStrongTypes());`;

const constructionSnippet = `NonEmptyString name = NonEmptyString.Create(input);   // throws on invalid
NonEmptyString? safe = NonEmptyString.TryCreate(input); // null on invalid
NonEmptyString? fluent = input.AsNonEmpty();             // same, as an extension`;
---

<BlogPostLayout metadata={metadata} lang={lang}>
  {
    lang === "cs" ? (
      <Fragment>
        <p>
          Když jsem dělal na backendu tohohle webu, pořád jsem narážel na to samé tření — a nebyla to záludná chyba ani chytrý algoritmus.
          Byla to validace. Přesněji řečeno to, kolikrát jsem musel to samé pravidlo napsat znovu. Ne z lajdáctví — každá vrstva má jinou
          práci a žádná z nich nemůže věřit té nad sebou.
        </p>

        <p>
          Vezměte si jeden endpoint, který zakládá objednávku. Jeho request DTO nese validační atributy, protože z nich vzniká OpenAPI
          schéma — frontend si z toho dokumentu generuje klienta i nápovědu k formulářům, takže pravidla musí být deklarovaná tam.
          Controller pak ta samá pravidla prověří ještě jednou, aby špatný request selhal hned s <code>400</code>, a ne až o tři databázové
          dotazy později. A service za ním je ověří potřetí, protože se k ní nedostanete jen přes tenhle controller. Tři kopie jednoho
          pravidla — a každé pole je lhář, dokud ho každá vrstva neusvědčí z opaku.
        </p>

        <Code code={beforeSnippet} lang="csharp" themes={codeThemes} />

        <p>
          Ty atributy dělají dvojí práci: vynutí <code>400</code> na hranici a zároveň se objeví v OpenAPI dokumentu. Ale dostanou vás jen
          do určité míry. Všimněte si, co tam <em>není</em> — žádné <code>[Required]</code>. Při zapnutých nullable reference types je
          non-nullable <code>string</code> už tak povinný a ví to jak validace modelu, tak generované schéma; atribut by byl jen šum. Co v
          krabici naopak chybí, je <code>[Positive]</code>, takže kladné celé číslo se píše jako <code>[Range(1, int.MaxValue)]</code> — to
          nejmíň špatné, co dostanete. A <code>[EmailAddress]</code> je proslule benevolentní — pustí i <code>a@b</code> — takže si
          controller e-mail stejně naparsuje přes <code>MailAddress</code>. Řekněme, že hranice je zhruba pokrytá. Pak ale request dorazí do
          service:
        </p>

        <Code code={beforeServiceSnippet} lang="csharp" themes={codeThemes} />

        <p>
          {" "}
          <code>PlaceAsync</code> bere obyčejné <code>string</code> a <code>int</code>. Netuší, že ho nějaký controller prověřil, a nic
          nebrání jinému volajícímu — background jobu, testu, příštímu endpointu — předat mu <code>""</code> a <code>-1</code>. Ten druhý
          volající často zrovna načetl <code>Order</code> z databáze a předává jeho pole rovnou dál; entita je uložila jako obyčejné
          sloupce, takže všechno, co se prokázalo na hranici, se ve chvíli uložení zploštilo zpátky na holý <code>string</code>. Tak to
          service kontroluje znovu — a musí odchytávat výjimky, které z té kontroly můžou vypadnout. Jedno pravidlo teď žije na třech
          místech — atributy, controller, service — každé se rozjíždí samostatně a každé si pěstuje vlastní testy. To je daň za posílání
          zvalidovaných dat v typech, které si nepamatují, že byly zvalidované.
        </p>

        <h2>Parse, don't validate</h2>

        <p>
          Náprava je stará myšlenka z funkcionálního programování: místo kontrolování hodnoty a posílání téhož volného typu dál ji{" "}
          <em>jednou</em> převeďte do typu, který neplatný stav vůbec neumí reprezentovat. <code>int</code>, který právě prošel kontrolou{" "}
          <code>&gt; 0</code>, je pořád jen <code>int</code> — důkaz se zahodí ve chvíli, kdy kontrola projde, takže další metoda níž musí
          kontrolovat znovu. <code>Positive&lt;int&gt;</code> si ten důkaz nese přímo v typu a kompilátor ho vymáhá všude níž.
        </p>

        <p>
          Přesně tohle pro C# balí můj balíček <a href={localePath(lang, "strong-types")}>Kalicz.StrongTypes</a>: malá sada validovaných
          obálek — <code>NonEmptyString</code>, <code>Email</code>, <code>Positive&lt;T&gt;</code> a spol. nad libovolným{" "}
          <code>INumber&lt;T&gt;</code>, <code>NonEmptyEnumerable&lt;T&gt;</code> — plus algebraické typy <code>Maybe&lt;T&gt;</code> a{" "}
          <code>Result&lt;T, TError&gt;</code>, kterými se to celé skládá dohromady. A brzy přibude <code>Interval&lt;T&gt;</code> — hodnota
          omezená na rozsah, poctivá náhrada onoho neohrabaného <code>[Range]</code> z dřívějška; věnuju mu samostatný článek.
        </p>

        <h2>Ta část „bez jediného řádku“</h2>

        <p>Jeden řádek na instalaci:</p>

        <Code code="dotnet add package Kalicz.StrongTypes" lang="shell" themes={codeThemes} />

        <p>Pak už jen request record vymění primitivy za typy, které říkají, co skutečně znamenají:</p>

        <Code code={afterSnippet} lang="csharp" themes={codeThemes} />

        <p>
          Trik je v tom, že balíček přináší konvertory pro <code>System.Text.Json</code>, které se nikde neregistrují. Když dorazí payload s
          prázdným kódem produktu nebo nulovým množstvím, selže už samotná deserializace a ASP.NET Core z ní udělá RFC 7807 <code>400</code>{" "}
          s pojmenovaným polem — dřív, než se metoda vašeho endpointu vůbec zavolá. Validační atributy, ruční parsování přes{" "}
          <code>MailAddress</code> i strážní klauzule v service — všechno pryč a nic je nenahradilo. Zmizel i <code>try/catch</code>:
          selhání, která zbyla, nejsou o tvaru dat — neznámý produkt, došlé zásoby — a vrací se jako <code>Result</code>, na který se
          přepnete, místo výjimek, které chytáte. Není tu žádná třída validátoru, žádná polévka z atributů, žádný pipeline behavior. Ty typy{" "}
          <em>jsou</em> ta validace.
        </p>

        <p>
          A frontend o nic nepřijde. Přidejte companion <code>Kalicz.StrongTypes.OpenApi.Swashbuckle</code> (nebo variantu pro{" "}
          <code>Microsoft.AspNetCore.OpenApi</code>) a zaregistrujte ho jedním voláním:
        </p>

        <Code code={openApiSetupSnippet} lang="csharp" themes={codeThemes} />

        <p>Generátor schématu pak ví, co každá obálka znamená, takže request výše vygeneruje přesně ta omezení, která klient potřebuje:</p>

        <Code code={openApiSnippet} lang="jsonc" themes={codeThemes} />

        <p>
          Dokument, ze kterého si frontend generuje klienta, je tak <em>přesnější</em> než ten ručně anotovaný — benevolentní pattern od{" "}
          <code>[EmailAddress]</code> nahradí opravdový <code>format</code>.
        </p>

        <h2>Signatury jako dokumentace</h2>

        <p>
          S čím jsem při psaní balíčku nepočítal, je to, jak daleko za hranici API se ten efekt nese. Jakmile okraj systému hodnoty jednou
          naparsuje do silných typů, každá vrstva pod ním může vyslovit své skutečné požadavky:
        </p>

        <Code code={signatureSnippet} lang="csharp" themes={codeThemes} />

        <p>
          Druhá signatura odpovídá na otázky, které vás ta první nutí dohledávat: ne, e-mail nemůže být null; ne, nulové množství sem
          nedoteče; ano, můžete to poslat rovnou do persistence. Kolegové na review se přestanou ptát „a co když je tohle prázdné?“, protože
          ta otázka už neprojde přes typovou kontrolu.
        </p>

        <p>
          Business pravidla, která selhat legitimně <em>můžou</em>, dostanou totéž přes <code>Result&lt;T, TError&gt;</code> — selhání je
          hodnota v signatuře, ne překvapení v podobě výjimky:
        </p>

        <Code code={resultSnippet} lang="csharp" themes={codeThemes} />

        <h2>Typy dorazí až do databáze</h2>

        <p>
          Vzpomínáte na entitu, která cestou dovnitř všechno zploštila zpátky na <code>string</code>? Nemusí. Přidejte companion{" "}
          <code>Kalicz.StrongTypes.EfCore</code> a silné typy se stanou přímo vlastnostmi entity — jediné volání na options builderu navěsí
          value converter na každou z nich:
        </p>

        <Code code={entitySnippet} lang="csharp" themes={codeThemes} />

        <p>
          Sloupec v databázi zůstává obyčejný <code>varchar</code> nebo <code>int</code>; na disku se nemění nic. Ale <code>Order</code>{" "}
          načtený za týden se vrátí se stejným <code>Email</code>, <code>NonEmptyString</code> a <code>Positive&lt;int&gt;</code>, se
          kterými odešel. Volající, který si entitu přečte a předá ji do <code>PlaceAsync</code>, už nemůže vrátit do hry stavy, proti
          kterým se service dřív bránila — důkaz je uložený spolu s daty, takže na cestě ven není co znovu validovat.
        </p>

        <h2>Méně hraničních případů, méně testů</h2>

        <p>
          Můj nejoblíbenější důsledek je, co se stane s testy. Ty, které do každé vrstvy sypaly <code>null</code>, <code>""</code>,{" "}
          <code>" "</code> a <code>-1</code>, aby ověřily, že se každá umí ubránit sama? Smazané. Ty stavy jsou nereprezentovatelné, takže
          není co bránit. Zbydou testy o chování — ty, které stojí za to číst. A na hranicích, kde hodnoty z volného vstupu opravdu
          konstruujete, je API explicitní v tom, co zamýšlíte:
        </p>

        <Code code={constructionSnippet} lang="csharp" themes={codeThemes} />

        <p>
          A pro vlastnosti, které si ověřit chcete, umí doprovodný balíček <code>Kalicz.StrongTypes.FsCheck</code> generovat validní silně
          typované hodnoty pro property-based testy — vaše generátory tak respektují stejné invarianty jako váš kód.
        </p>

        <h2>Vyzkoušejte to</h2>

        <p>
          Backend tohohle webu běží na StrongTypes od kraje ke kraji — request DTO, doménové eventy, stav entit. Pokud vás ten přístup
          zaujal, na stránce <a href={localePath(lang, "strong-types")}>StrongTypes</a> najdete diagramy a další ukázky, zdrojáky žijí na{" "}
          <a href="https://github.com/KaliCZ/StrongTypes" target="_blank" rel="noopener noreferrer">
            GitHubu
          </a>{" "}
          a balíček je na{" "}
          <a href="https://www.nuget.org/packages/Kalicz.StrongTypes" target="_blank" rel="noopener noreferrer">
            NuGetu
          </a>
          . Začněte jedním request recordem. Smažte guard clauses, které tím ztratí smysl. Do odpoledne budete vědět, jestli ho chcete
          všude.
        </p>
      </Fragment>
    ) : (
      <Fragment>
        <p>
          On one of my previous projects, I noticed a friction that caused bugs sometimes. It was validation, and specifically how many
          times I had to write the same rule down.
        </p>

        <p>
          Take this example endpoint that places an order. Data annotations validate the request DTO - those become the OpenAPI schema,
          enabling frontend validations. The controller then checks some rules that can't be mapped to OpenAPI, but we want to fail before
          we trigger DB queries in order to fail fast. And the service with business logic checks a third time, because it isn't only
          reachable through that controller and it has to guarantee validity. Three copies of one rule — and a possibility to introduce bugs
          just by forgetting to update something.
        </p>

        <Code code={beforeSnippet} lang="csharp" themes={codeThemes} />

        <p>
          Notice that data annotations validate email addresses. But you still only have string. Similarly, the integer is validated to be
          positive, but you can't actually use that information. Then the request reaches the service:
        </p>

        <Code code={beforeServiceSnippet} lang="csharp" themes={codeThemes} />

        <p>
          {" "}
          <code>PlaceAsync</code> is ultimately responsible that everything works. It can be called from the controller or it can also be
          called from some background worker or other endpoint. So we must validate again.
        </p>

        <h2>Parse, don't validate</h2>

        <p>
          The fix is an old functional-programming idea: instead of checking a value and passing the same loose type along, convert it{" "}
          <em>once</em> into a type that cannot represent the invalid state. An <code>int</code> that just passed a <code>&gt; 0</code>{" "}
          check is still an <code>int</code> — the proof is discarded the moment the check succeeds, so the next method down has to check
          all over again. A <code>Positive&lt;int&gt;</code> carries that proof in the type itself, and the compiler enforces it everywhere
          downstream.
        </p>

        <p>
          That's what my <a href={localePath(lang, "strong-types")}>Kalicz.StrongTypes</a> package packages up for C#: a small set of
          validated wrappers — <code>NonEmptyString</code>, <code>Email</code>, <code>Positive&lt;T&gt;</code> and friends over any{" "}
          <code>INumber&lt;T&gt;</code>, <code>NonEmptyEnumerable&lt;T&gt;</code> — plus the algebraic types <code>Maybe&lt;T&gt;</code> and{" "}
          <code>Result&lt;T, TError&gt;</code> to compose them with.
        </p>

        <p>
          I will also be extending the library in the future. For example, <code>Interval&lt;T&gt;</code> is coming to make it easier to
          represent start + end with validations that end is after start. I'll write a separate blog post about that one.
        </p>

        <h2>The zero-code part</h2>

        <p>One line to install:</p>

        <Code code="dotnet add package Kalicz.StrongTypes" lang="shell" themes={codeThemes} />

        <p>Then the request record swaps its primitives for types that mean what they say:</p>

        <Code code={afterSnippet} lang="csharp" themes={codeThemes} />

        <p>
          Data annotations are gone. Mapping to MailAddress is gone. All the info about the values is stored in types. And the method
          returns a result, so we don't need to catch exceptions. So our compiler knows what possible errors can happen.
        </p>

        <p>
          All the types serialize to and from JSON out of the box. And the OpenAPI schema is also properly updated — add the{" "}
          <code>Kalicz.StrongTypes.OpenApi.Swashbuckle</code> package (or the <code>Microsoft.AspNetCore.OpenApi</code> variant) and
          register it:
        </p>

        <Code code={openApiSetupSnippet} lang="csharp" themes={codeThemes} />

        <p>Then the request above emits exactly the constraints a client needs:</p>

        <Code code={openApiSnippet} lang="jsonc" themes={codeThemes} />

        <h2>Signatures become documentation</h2>

        <p>The nicest part is how it makes your code much easier to understand. Every method gets to state its real requirements:</p>

        <Code code={signatureSnippet} lang="csharp" themes={codeThemes} />

        <p>
          The second signature answers questions the first one forces you to research: no, the code can't be empty; no, zero quantity can't
          happen here; yes, you can pass this straight to the persistence layer. Reviewers stop asking "what if
          '&lbrace;insertProblem&rbrace;' happens?" because the question no longer type-checks.
        </p>

        <p>
          Business rules that <em>can</em> legitimately fail get the same treatment with <code>Result&lt;T, TError&gt;</code> — failure
          becomes a value in the signature instead of a surprise exception:
        </p>

        <Code code={resultSnippet} lang="csharp" themes={codeThemes} />

        <h2>The types reach the database</h2>

        <p>
          If you load an entity into context via EF core, you'd have to validate again. But with the <code>Kalicz.StrongTypes.EfCore</code>{" "}
          companion package, the strong types become entity properties directly — one call on the options builder attaches a value converter
          to each:
        </p>

        <Code code={entitySnippet} lang="csharp" themes={codeThemes} />

        <p>
          The Db column is still a plain <code>varchar</code> or <code>int</code>; nothing changes about the storage. But EF core now
          doesn't allow storing invalid values. And if you try to load invalid values from DB, you get a loud crash instead of a silent
          null. So the parsed information is kept forever. You can load the entity and call
          <code>PlaceAsync</code> safely.
        </p>

        <h2>Fewer edge cases, fewer tests</h2>

        <p>
          The amount of unit tests necessary has dropped massively - these edge cases are simply not possible anymore. You can't pass{" "}
          <code>null</code>, <code>""</code>,<code>" "</code> as a NonEmptyString. You can't pass <code>-1</code> into quantity. What
          remains are tests about behavior — the ones worth reading. At the boundaries where you do construct values from loose input, the
          API is explicit about intent:
        </p>

        <Code code={constructionSnippet} lang="csharp" themes={codeThemes} />

        <p>
          And for the properties you still want to verify, the <code>Kalicz.StrongTypes.FsCheck</code> companion package generates valid
          strong-typed values for property-based tests, so your generators respect the same invariants your code does. Property-based
          testing allows you to define one test method, but run hundreds of various values through it. Let me know in a comment if you'd
          like a separate blog post about that.
        </p>

        <h2>Try it</h2>

        <p>
          Even the backend behind this very site runs on StrongTypes — request DTOs, domain events, entity state. If the approach appeals to
          you, the <a href={localePath(lang, "strong-types")}>StrongTypes page</a> has diagrams and more examples, the source lives on{" "}
          <a href="https://github.com/KaliCZ/StrongTypes" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
          , and the package is on{" "}
          <a href="https://www.nuget.org/packages/Kalicz.StrongTypes" target="_blank" rel="noopener noreferrer">
            NuGet
          </a>
          . Start with one request record. Delete the guard clauses that become redundant. You'll know within an afternoon that you want it
          everywhere.
        </p>
      </Fragment>
    )
  }
</BlogPostLayout>
