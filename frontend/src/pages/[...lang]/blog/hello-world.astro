---
import BlogPostLayout from "../../../components/BlogPostLayout.astro";
import { blogPostStaticPaths, type BlogPostMetadata } from "../../../blog/types";
import { defaultLocale, type Locale } from "../../../i18n/utils";

export const metadata: BlogPostMetadata = {
  variants: {
    en: {
      title: "Hello, World",
      summary: "A quick hello — who I am and what this blog is going to be about (mostly developer experience).",
    },
    cs: {
      title: "Ahoj, světe",
      summary: "Krátké přivítání — kdo jsem a o čem tenhle blog nejspíš bude (hlavně o developer experience).",
    },
  },
  pubDate: "2026-07-03",
  tags: ["meta"],
};

export const getStaticPaths = () => blogPostStaticPaths(metadata);

const lang = (Astro.params.lang ?? defaultLocale) as Locale;
---

<BlogPostLayout metadata={metadata} lang={lang}>
  {
    lang === "cs" ? (
      <Fragment>
        <p>Ahoj, já jsem Pavel — a tohle je můj blog, kam budu čas od času házet svoje nápady, názory a zkušenosti.</p>
        <p>Nejvíc mě baví DX (developer experience), takže o tom nejspíš bude i většina zdejších příspěvků.</p>
      </Fragment>
    ) : (
      <Fragment>
        <p>Hello, I'm Pavel — and this is my blog, where I might dump my ideas, opinions, and experiences every once in a while.</p>
        <p>I mostly focus on DX (developer experience), so that's probably what most of these posts end up being about.</p>
      </Fragment>
    )
  }
</BlogPostLayout>
