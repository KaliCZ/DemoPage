---
import Layout from "../../../layouts/Layout.astro";
import BlogRssLink from "../../../components/BlogRssLink.astro";
import BlogList from "../../../components/blog/BlogList.vue";
import { locales, defaultLocale, localePath, type Locale } from "../../../i18n/utils";
import type { PageMeta } from "../../../lib/page-meta";
import type { BlogListPost } from "../../../lib/blog/types";
import { publishedPosts, resolveVariant } from "../../../blog/posts";
import enStrings from "../../../i18n/en/blog.json";
import csStrings from "../../../i18n/cs/blog.json";

const translations = { en: enStrings, cs: csStrings };

export const pageMeta: PageMeta = { updatedDate: "2026-07-08" };

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }));
}

const lang = (Astro.params.lang ?? defaultLocale) as Locale;
const t = translations[lang];

const posts = publishedPosts();
const dateLocale = lang === "cs" ? "cs-CZ" : "en-US";
const formatDate = (date: Date) => date.toLocaleDateString(dateLocale, { year: "numeric", month: "long", day: "numeric" });

// The island renders the cards (build-time SSR keeps the list crawlable), so all
// display strings are resolved here. A post without a variant in this language is
// listed anyway — under its own language's title and URL, with a chip.
const listPosts: BlogListPost[] = posts.map((post) => {
  const { locale, variant } = resolveVariant(post, lang);
  const crossLocale = locale !== lang ? locale : undefined;
  return {
    slug: post.slug,
    url: localePath(locale, `blog/${post.slug}`),
    title: variant.title,
    summary: variant.summary,
    tags: post.metadata.tags,
    pubDateIso: post.metadata.pubDate,
    pubDateLabel: formatDate(post.pubDate),
    updatedDateIso: post.metadata.updatedDate,
    updatedDateLabel: post.updatedDate && post.metadata.updatedDate ? formatDate(post.updatedDate) : undefined,
    crossLocale,
    crossLocaleLabel: crossLocale ? t.index.language[crossLocale] : undefined,
  };
});

const apiUrl = import.meta.env.PUBLIC_API_URL || "";
---

<Layout title={t.meta.title} description={t.meta.description} activePage="blog" lang={lang}>
  <section class="max-w-3xl mx-auto px-4 md:px-8">
    <div class="mb-12 md:mb-16">
      <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-[1.1] text-on-surface">
        {t.index.title}
      </h1>
      <p class="font-body text-lg md:text-xl text-on-surface-variant leading-relaxed">
        {t.index.subtitle}
      </p>
      <BlogRssLink label={t.rss.label} title={t.rss.title} class="mt-6" />
    </div>

    {posts.length === 0 && <p class="font-body text-on-surface-variant">{t.index.empty}</p>}

    {
      posts.length > 0 && (
        <BlogList
          client:idle
          apiUrl={apiUrl}
          posts={listPosts}
          t={{
            updatedOn: t.index.updatedOn,
            sortLabel: t.index.sortLabel,
            sortRecent: t.index.sortRecent,
            sortReactions: t.index.sortReactions,
            sortViews: t.index.sortViews,
            unreadOnly: t.index.unreadOnly,
            unreadEmpty: t.index.unreadEmpty,
            statViews: t.index.statViews,
            statReactions: t.index.statReactions,
            paginationPrev: t.index.paginationPrev,
            paginationNext: t.index.paginationNext,
            paginationPage: t.index.paginationPage,
            readState: t.readState,
          }}
        />
      )
    }
  </section>
</Layout>
