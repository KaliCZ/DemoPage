---
import Layout from '../../layouts/Layout.astro';
import { locales, defaultLocale, localePath, type Locale } from '../../i18n/utils';
import enStrings from '../../i18n/en/job-offers.json';
import csStrings from '../../i18n/cs/job-offers.json';
import enHireMe from '../../i18n/en/hire-me.json';
import csHireMe from '../../i18n/cs/hire-me.json';

const translations = { en: enStrings, cs: csStrings };
const formTranslations = { en: enHireMe, cs: csHireMe };

export function getStaticPaths() {
  return locales.map(lang => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }));
}

const lang = (Astro.params.lang ?? defaultLocale) as Locale;
const t = translations[lang];
const f = formTranslations[lang].form;
---

<Layout title={t.meta.title} description={t.meta.description} activePage="job-offers" lang={lang}>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-8 mb-16">
    <h1 id="page-title" class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none mb-6">
      <span class="gradient-text text-primary bg-linear-to-r from-primary to-tertiary">{t.hero.title}</span>
    </h1>
    <p id="page-subtitle" class="text-lg text-on-surface-variant font-body max-w-xl">{t.hero.subtitle}</p>
  </section>

  <!-- Login prompt -->
  <section id="login-prompt" class="max-w-5xl mx-auto px-8 mb-16">
    <div class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12 text-center">
      <span class="material-symbols-outlined text-5xl text-primary mb-4 block" aria-hidden="true">lock</span>
      <h2 class="font-headline text-2xl font-bold text-on-surface mb-3">{t.loginPrompt.title}</h2>
      <p class="text-on-surface-variant font-body mb-6">{t.loginPrompt.description}</p>
      <button id="offers-sign-in" type="button"
        class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer">
        {t.loginPrompt.signInButton}
      </button>
    </div>
  </section>

  <!-- Offers list -->
  <section id="offers-list-section" class="hidden max-w-5xl mx-auto px-8 mb-16">
    <!-- Status filter -->
    <div id="status-filter" class="hidden flex flex-wrap gap-2 mb-6" role="group" aria-label={t.list.status}>
      <button type="button" data-status="" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-primary text-on-primary">
        {t.list.filterAll}
      </button>
      <button type="button" data-status="Submitted" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest">
        {t.list.submitted}
      </button>
      <button type="button" data-status="InReview" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest">
        {t.list.inReview}
      </button>
      <button type="button" data-status="LetsTalk" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest">
        {t.list.accepted}
      </button>
      <button type="button" data-status="Declined" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest">
        {t.list.declined}
      </button>
      <button type="button" data-status="Cancelled" class="status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest">
        {t.list.cancelled}
      </button>
    </div>

    <div id="offers-loading" class="text-center py-12">
      <span class="material-symbols-outlined text-3xl text-on-surface-variant animate-spin" aria-hidden="true">progress_activity</span>
    </div>
    <div id="offers-empty" class="hidden bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12 text-center">
      <span class="material-symbols-outlined text-5xl text-on-surface-variant/50 mb-4 block" aria-hidden="true">inbox</span>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">{t.empty.title}</h2>
      <p class="text-on-surface-variant font-body mb-6">{t.empty.description}</p>
      <a href={localePath(lang, 'hire-me')}
        class="inline-block px-6 py-3 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors">
        {t.empty.cta}
      </a>
    </div>
    <div id="offers-grid" class="hidden grid gap-4"></div>
  </section>

  <!-- Detail view -->
  <section id="offer-detail-section" class="hidden max-w-3xl mx-auto px-8 mb-16">
    <button id="back-to-list" type="button" class="flex items-center gap-2 text-sm font-label text-on-surface-variant hover:text-primary transition-colors mb-8 cursor-pointer">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_back</span>
      {t.list.back}
    </button>
    <div id="offer-detail" class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12"></div>

    <!-- Edit form (hidden by default, shown when editing) -->
    <div id="edit-form-section" class="hidden mt-6">
      <form id="edit-form" class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="edit-companyName" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.companyName}</label>
            <input type="text" id="edit-companyName" name="companyName" required maxlength="200" placeholder={f.companyNamePlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="edit-contactName" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.contactName}</label>
            <input type="text" id="edit-contactName" name="contactName" required maxlength="200" placeholder={f.contactNamePlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="edit-contactEmail" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.contactEmail}</label>
            <input type="email" id="edit-contactEmail" name="contactEmail" required maxlength="255" placeholder={f.contactEmailPlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="edit-jobTitle" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.jobTitle}</label>
            <input type="text" id="edit-jobTitle" name="jobTitle" required maxlength="200" placeholder={f.jobTitlePlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
        </div>
        <div>
          <label for="edit-description" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.description}</label>
          <textarea id="edit-description" name="description" required maxlength="5000" rows="5" placeholder={f.descriptionPlaceholder}
            class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"></textarea>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="edit-salaryRange" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.salaryRange}</label>
            <input type="text" id="edit-salaryRange" name="salaryRange" maxlength="100" placeholder={f.salaryRangePlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
          <div>
            <label for="edit-location" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.location}</label>
            <input type="text" id="edit-location" name="location" maxlength="200" placeholder={f.locationPlaceholder}
              class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
          </div>
        </div>
        <div class="flex items-center gap-3">
          <input type="checkbox" id="edit-isRemote" name="isRemote"
            class="w-5 h-5 rounded border-outline-variant/20 text-primary focus:ring-primary/30 accent-primary" />
          <label for="edit-isRemote" class="text-sm font-label font-semibold text-on-surface">{f.isRemote}</label>
        </div>
        <div>
          <label for="edit-additionalNotes" class="block text-sm font-label font-semibold text-on-surface mb-2">{f.additionalNotes}</label>
          <textarea id="edit-additionalNotes" name="additionalNotes" maxlength="2000" rows="3" placeholder={f.additionalNotesPlaceholder}
            class="w-full px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"></textarea>
        </div>
        <div id="edit-error" class="hidden text-error text-sm font-body"></div>
        <div class="flex gap-4">
          <button type="submit" class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer">
            {t.list.editSave}
          </button>
          <button type="button" id="edit-discard" class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-surface-container-high text-on-surface hover:bg-surface-container-highest transition-colors cursor-pointer">
            {t.list.editCancel}
          </button>
        </div>
      </form>
    </div>

    <!-- User actions (edit / cancel) -->
    <div id="user-actions" class="hidden mt-6 flex gap-4">
      <button id="edit-btn" type="button"
        class="hidden flex items-center gap-2 px-6 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">edit</span>
        {t.list.edit}
      </button>
      <button id="cancel-btn" type="button"
        class="hidden flex items-center gap-2 px-6 py-2 rounded-xl text-sm font-semibold font-label bg-error text-on-primary hover:bg-error/90 transition-colors cursor-pointer">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">cancel</span>
        {t.list.cancel}
      </button>
    </div>

    <!-- Cancel confirmation -->
    <div id="cancel-controls" class="hidden mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">{t.list.cancel}</h3>
      <p class="text-sm text-on-surface-variant font-body mb-4">{t.list.cancelConfirm}</p>
      <textarea id="cancel-reason" rows="2" placeholder={t.list.cancelReason}
        class="w-full px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y mb-4"></textarea>
      <button id="confirm-cancel" type="button"
        class="px-6 py-2 rounded-xl text-sm font-semibold font-label bg-error text-on-primary hover:bg-error/90 transition-colors cursor-pointer">
        {t.list.cancelButton}
      </button>
    </div>

    <!-- Admin status update -->
    <div id="admin-controls" class="hidden mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">{t.list.updateStatus}</h3>
      <div class="flex flex-col sm:flex-row gap-4">
        <select id="status-select" class="px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm focus:outline-none focus:ring-2 focus:ring-primary/30">
          <option value="Submitted">{t.list.submitted}</option>
          <option value="InReview">{t.list.inReview}</option>
          <option value="LetsTalk">{t.list.accepted}</option>
          <option value="Declined">{t.list.declined}</option>
        </select>
        <textarea id="admin-notes-input" rows="2" placeholder={t.list.adminNotes}
          class="flex-1 px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y"></textarea>
        <button id="save-status" type="button"
          class="px-6 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer self-start">
          {t.list.save}
        </button>
      </div>
    </div>

    <!-- Comments -->
    <div id="comments-section" class="mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">
        <span class="material-symbols-outlined text-lg align-middle mr-1" aria-hidden="true">chat</span>
        {t.list.comments}
      </h3>
      <div id="comments-list" class="space-y-4 mb-4"></div>
      <div class="flex gap-3">
        <textarea id="comment-input" rows="2" placeholder={t.list.commentPlaceholder}
          class="flex-1 px-4 py-2 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface font-body text-sm placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-y"></textarea>
        <button id="send-comment" type="button"
          class="px-5 py-2 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer self-end">
          {t.list.commentSend}
        </button>
      </div>
    </div>

    <!-- Activity log -->
    <div id="history-section" class="mt-6 bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">
        <span class="material-symbols-outlined text-lg align-middle mr-1" aria-hidden="true">history</span>
        {t.list.history}
      </h3>
      <div id="history-list" class="space-y-3"></div>
    </div>
  </section>

  <script define:vars={{
    apiUrl: import.meta.env.PUBLIC_API_URL || 'http://localhost:5000',
    hireMeUrl: localePath(lang, 'hire-me'),
    statusLabels: { Submitted: t.list.submitted, InReview: t.list.inReview, LetsTalk: t.list.accepted, Declined: t.list.declined, Cancelled: t.list.cancelled },
    remoteLabel: t.list.remote,
    submittedByLabel: t.list.submittedBy,
    adminNotesLabel: t.list.adminNotes,
    heroTitleAdmin: t.hero.titleAdmin,
    heroSubtitleAdmin: t.hero.subtitleAdmin,
    historyEmptyLabel: t.list.historyEmpty,
    commentsEmptyLabel: t.list.commentsEmpty,
    errorText: 'Something went wrong. Please try again.',
    attachmentsLabel: t.list.attachments,
    downloadLabel: t.list.download
  }}>
    // TODO: Remove once uptime monitoring (e.g. Sentry) keeps the DB alive.
    // Wake up the database (see hire-me.astro for details).
    fetch(apiUrl + '/health').catch(function() {});

    var isAdmin = false;
    var currentOfferId = null;
    var currentOffer = null;
    var currentToken = null;
    var activeStatus = '';

    var statusColors = {
      Submitted: 'bg-secondary-container text-on-surface',
      InReview: 'bg-primary-container text-on-primary-container',
      LetsTalk: 'bg-tertiary-container text-on-surface',
      Declined: 'bg-error-container text-on-surface',
      Cancelled: 'bg-surface-container-high text-on-surface-variant'
    };

    var eventIcons = {
      Submitted: 'send',
      Edited: 'edit',
      StatusChanged: 'swap_horiz',
      Cancelled: 'cancel',
      Comment: 'chat_bubble'
    };

    window.addEventListener('auth-change', async function(e) {
      var user = e.detail?.user;
      if (user) {
        document.getElementById('login-prompt')?.classList.add('hidden');
        document.getElementById('offers-list-section')?.classList.remove('hidden');
        await loadOffers();
      } else {
        document.getElementById('login-prompt')?.classList.remove('hidden');
        document.getElementById('offers-list-section')?.classList.add('hidden');
      }
    });

    document.getElementById('offers-sign-in')?.addEventListener('click', function() {
      document.getElementById('auth-sign-in-desktop')?.click();
    });

    async function loadOffers() {
      currentToken = await window.__getAccessToken?.();
      if (!currentToken) return;

      var statusParam = activeStatus ? '?status=' + activeStatus : '';
      var response = await fetch(apiUrl + '/api/job-offers' + statusParam, {
        headers: { 'Authorization': 'Bearer ' + currentToken }
      });

      if (response.status === 403) {
        isAdmin = false;
        response = await fetch(apiUrl + '/api/job-offers/mine' + statusParam, {
          headers: { 'Authorization': 'Bearer ' + currentToken }
        });
      } else {
        isAdmin = true;
        var titleEl = document.getElementById('page-title');
        var subtitleEl = document.getElementById('page-subtitle');
        if (titleEl) titleEl.innerHTML = '<span class="gradient-text text-primary bg-linear-to-r from-primary to-tertiary">' + heroTitleAdmin + '</span>';
        if (subtitleEl) subtitleEl.textContent = heroSubtitleAdmin;
      }

      document.getElementById('offers-loading')?.classList.add('hidden');
      document.getElementById('status-filter')?.classList.remove('hidden');
      if (!response.ok) return;

      var data = await response.json();
      if (data.items.length === 0) {
        document.getElementById('offers-empty')?.classList.remove('hidden');
        document.getElementById('offers-grid')?.classList.add('hidden');
        return;
      }

      document.getElementById('offers-empty')?.classList.add('hidden');
      var grid = document.getElementById('offers-grid');
      if (!grid) return;
      grid.classList.remove('hidden');
      grid.innerHTML = '';

      data.items.forEach(function(offer) {
        var card = document.createElement('div');
        card.className = 'bg-surface-container-low rounded-2xl border border-outline-variant/10 p-6 hover:border-primary/20 transition-colors cursor-pointer';
        card.innerHTML = '<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">' +
          '<div class="flex-1 min-w-0">' +
            '<h3 class="font-headline text-lg font-bold text-on-surface truncate">' + esc(offer.jobTitle) + '</h3>' +
            '<p class="text-sm text-on-surface-variant font-body">' + esc(offer.companyName) + '</p>' +
          '</div>' +
          '<div class="flex items-center gap-3 flex-shrink-0">' +
            (offer.isRemote ? '<span class="px-3 py-1 rounded-full text-xs font-label font-semibold bg-tertiary-container text-on-surface">' + remoteLabel + '</span>' : '') +
            '<span class="px-3 py-1 rounded-full text-xs font-label font-semibold ' + (statusColors[offer.status] || '') + '">' + (statusLabels[offer.status] || offer.status) + '</span>' +
            '<span class="text-xs text-on-surface-variant font-label">' + new Date(offer.createdAt).toLocaleDateString() + '</span>' +
          '</div>' +
        '</div>';
        card.addEventListener('click', function() { showDetail(offer.id); });
        grid.appendChild(card);
      });
    }

    async function showDetail(id) {
      currentOfferId = id;
      document.getElementById('offers-list-section')?.classList.add('hidden');
      document.getElementById('offer-detail-section')?.classList.remove('hidden');
      document.getElementById('edit-form-section')?.classList.add('hidden');
      document.getElementById('cancel-controls')?.classList.add('hidden');

      var headers = { 'Authorization': 'Bearer ' + currentToken };
      var [detailRes, historyRes, commentsRes] = await Promise.all([
        fetch(apiUrl + '/api/job-offers/' + id, { headers }),
        fetch(apiUrl + '/api/job-offers/' + id + '/history', { headers }),
        fetch(apiUrl + '/api/job-offers/' + id + '/comments', { headers })
      ]);

      if (!detailRes.ok) return;
      var offer = await detailRes.json();
      currentOffer = offer;

      renderDetail(offer);
      renderControls(offer);
      if (historyRes.ok) renderHistory(await historyRes.json());
      if (commentsRes.ok) renderComments(await commentsRes.json());
    }

    function renderDetail(offer) {
      var detail = document.getElementById('offer-detail');
      if (!detail) return;
      detail.innerHTML =
        '<div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-8">' +
          '<div>' +
            '<h2 class="font-headline text-2xl font-bold text-on-surface mb-1">' + esc(offer.jobTitle) + '</h2>' +
            '<p class="text-on-surface-variant font-body">' + esc(offer.companyName) + '</p>' +
          '</div>' +
          '<span class="px-4 py-1.5 rounded-full text-sm font-label font-semibold ' + (statusColors[offer.status] || '') + ' self-start">' + (statusLabels[offer.status] || offer.status) + '</span>' +
        '</div>' +
        '<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">' +
          '<div><p class="text-xs font-label text-on-surface-variant mb-1">Contact</p><p class="text-sm font-body text-on-surface">' + esc(offer.contactName) + '</p><p class="text-sm font-body text-on-surface-variant">' + esc(offer.contactEmail) + '</p></div>' +
          '<div><p class="text-xs font-label text-on-surface-variant mb-1">Location</p><p class="text-sm font-body text-on-surface">' + (offer.location ? esc(offer.location) : '—') + (offer.isRemote ? ' <span class="text-tertiary">(' + remoteLabel + ')</span>' : '') + '</p></div>' +
          (offer.salaryRange ? '<div><p class="text-xs font-label text-on-surface-variant mb-1">Salary</p><p class="text-sm font-body text-on-surface">' + esc(offer.salaryRange) + '</p></div>' : '') +
          '<div><p class="text-xs font-label text-on-surface-variant mb-1">Submitted</p><p class="text-sm font-body text-on-surface">' + new Date(offer.createdAt).toLocaleString() + '</p></div>' +
        '</div>' +
        '<div class="mb-6"><p class="text-xs font-label text-on-surface-variant mb-2">Description</p><p class="text-sm font-body text-on-surface whitespace-pre-line">' + esc(offer.description) + '</p></div>' +
        (offer.additionalNotes ? '<div class="mb-6"><p class="text-xs font-label text-on-surface-variant mb-2">Additional Notes</p><p class="text-sm font-body text-on-surface whitespace-pre-line">' + esc(offer.additionalNotes) + '</p></div>' : '') +
        (offer.attachments && offer.attachments.length > 0 ?
          '<div class="mb-6"><p class="text-xs font-label text-on-surface-variant mb-2">' + attachmentsLabel + '</p>' +
          '<div class="space-y-2">' +
          offer.attachments.map(function(att) {
            var sizeStr = att.fileSize >= 1024 * 1024
              ? (att.fileSize / 1024 / 1024).toFixed(1) + ' MB'
              : Math.round(att.fileSize / 1024) + ' KB';
            return '<div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-container border border-outline-variant/10 text-sm">' +
              '<span class="material-symbols-outlined text-lg text-on-surface-variant" aria-hidden="true">description</span>' +
              '<span class="flex-1 truncate font-body text-on-surface">' + esc(att.fileName) + '</span>' +
              '<span class="text-xs text-on-surface-variant font-label">' + sizeStr + '</span>' +
              '<button type="button" data-file-name="' + esc(att.fileName) + '" class="download-attachment-btn flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-label font-semibold text-primary hover:bg-primary/10 transition-colors cursor-pointer">' +
                '<span class="material-symbols-outlined text-sm" aria-hidden="true">download</span>' + downloadLabel +
              '</button>' +
            '</div>';
          }).join('') +
          '</div></div>' : '') +
        (isAdmin && offer.userEmail ? '<div class="pt-4 border-t border-outline-variant/10"><p class="text-xs font-label text-on-surface-variant">' + submittedByLabel + ': ' + esc(offer.userEmail) + '</p></div>' : '') +
        (isAdmin && offer.adminNotes ? '<div class="mt-4"><p class="text-xs font-label text-on-surface-variant mb-1">' + adminNotesLabel + '</p><p class="text-sm font-body text-on-surface-variant italic">' + esc(offer.adminNotes) + '</p></div>' : '');

      // Bind download buttons
      detail.querySelectorAll('.download-attachment-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var fileName = btn.getAttribute('data-file-name');
          if (!currentOfferId || !fileName || !currentToken) return;

          var encodedName = encodeURIComponent(fileName);
          var response = await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/attachments/' + encodedName, {
            headers: { 'Authorization': 'Bearer ' + currentToken }
          });

          if (!response.ok) return;

          var blob = await response.blob();
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = fileName;
          a.click();
          URL.revokeObjectURL(url);
        });
      });
    }

    function renderControls(offer) {
      var isOwner = !isAdmin;
      var canEdit = isOwner && offer.status === 'Submitted';
      var canCancel = isOwner && (offer.status === 'Submitted' || offer.status === 'InReview');

      // User actions bar
      var actionsEl = document.getElementById('user-actions');
      var editBtn = document.getElementById('edit-btn');
      var cancelBtn = document.getElementById('cancel-btn');
      if (actionsEl) actionsEl.classList.toggle('hidden', !canEdit && !canCancel);
      if (editBtn) editBtn.classList.toggle('hidden', !canEdit);
      if (cancelBtn) cancelBtn.classList.toggle('hidden', !canCancel);

      // Admin controls
      if (isAdmin && offer.status !== 'Cancelled') {
        document.getElementById('admin-controls')?.classList.remove('hidden');
        var select = document.getElementById('status-select');
        if (select) select.value = offer.status;
        var notes = document.getElementById('admin-notes-input');
        if (notes) notes.value = offer.adminNotes || '';
      } else {
        document.getElementById('admin-controls')?.classList.add('hidden');
      }
    }

    function renderHistory(history) {
      var historyList = document.getElementById('history-list');
      if (!historyList) return;
      // Filter out Comment events — those are shown in the comments section
      var entries = history.entries.filter(function(e) { return e.eventType !== 'Comment'; });
      if (entries.length === 0) {
        historyList.innerHTML = '<p class="text-sm text-on-surface-variant font-body">' + historyEmptyLabel + '</p>';
        return;
      }
      historyList.innerHTML = '';
      entries.forEach(function(entry) {
        var icon = eventIcons[entry.eventType] || 'info';
        var el = document.createElement('div');
        el.className = 'flex items-start gap-3 text-sm';
        el.innerHTML =
          '<span class="material-symbols-outlined text-lg text-on-surface-variant mt-0.5 flex-shrink-0" aria-hidden="true">' + icon + '</span>' +
          '<div class="flex-1 min-w-0">' +
            '<p class="font-body text-on-surface">' + esc(entry.description) + '</p>' +
            '<p class="text-xs font-label text-on-surface-variant mt-0.5">' + esc(entry.actorEmail) + ' · ' + new Date(entry.timestamp).toLocaleString() + '</p>' +
          '</div>';
        historyList.appendChild(el);
      });
    }

    function renderComments(data) {
      var list = document.getElementById('comments-list');
      if (!list) return;
      if (data.comments.length === 0) {
        list.innerHTML = '<p class="text-sm text-on-surface-variant font-body">' + commentsEmptyLabel + '</p>';
        return;
      }
      list.innerHTML = '';
      data.comments.forEach(function(c) {
        var el = document.createElement('div');
        el.className = 'flex gap-3';
        el.innerHTML =
          '<div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center flex-shrink-0">' +
            '<span class="text-xs font-bold text-on-primary-container">' + esc(c.userName.charAt(0).toUpperCase()) + '</span>' +
          '</div>' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-baseline gap-2">' +
              '<span class="text-sm font-label font-semibold text-on-surface">' + esc(c.userName) + '</span>' +
              '<span class="text-xs font-label text-on-surface-variant">' + new Date(c.createdAt).toLocaleString() + '</span>' +
            '</div>' +
            '<p class="text-sm font-body text-on-surface mt-1 whitespace-pre-line">' + esc(c.content) + '</p>' +
          '</div>';
        list.appendChild(el);
      });
    }

    // Edit button
    document.getElementById('edit-btn')?.addEventListener('click', function() {
      if (!currentOffer) return;
      var o = currentOffer;
      document.getElementById('edit-companyName').value = o.companyName;
      document.getElementById('edit-contactName').value = o.contactName;
      document.getElementById('edit-contactEmail').value = o.contactEmail;
      document.getElementById('edit-jobTitle').value = o.jobTitle;
      document.getElementById('edit-description').value = o.description;
      document.getElementById('edit-salaryRange').value = o.salaryRange || '';
      document.getElementById('edit-location').value = o.location || '';
      document.getElementById('edit-isRemote').checked = o.isRemote;
      document.getElementById('edit-additionalNotes').value = o.additionalNotes || '';

      document.getElementById('offer-detail')?.classList.add('hidden');
      document.getElementById('user-actions')?.classList.add('hidden');
      document.getElementById('edit-form-section')?.classList.remove('hidden');
    });

    document.getElementById('edit-discard')?.addEventListener('click', function() {
      document.getElementById('edit-form-section')?.classList.add('hidden');
      document.getElementById('offer-detail')?.classList.remove('hidden');
      document.getElementById('user-actions')?.classList.remove('hidden');
    });

    document.getElementById('edit-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      var form = e.target;
      var errEl = document.getElementById('edit-error');
      if (errEl) errEl.classList.add('hidden');

      var body = {
        companyName: form.companyName.value,
        contactName: form.contactName.value,
        contactEmail: form.contactEmail.value,
        jobTitle: form.jobTitle.value,
        description: form.description.value,
        salaryRange: form.salaryRange.value || null,
        location: form.location.value || null,
        isRemote: form.isRemote.checked,
        additionalNotes: form.additionalNotes.value || null
      };

      var res = await fetch(apiUrl + '/api/job-offers/' + currentOfferId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + currentToken },
        body: JSON.stringify(body)
      });

      if (res.ok) {
        await showDetail(currentOfferId);
      } else {
        if (errEl) { errEl.textContent = errorText; errEl.classList.remove('hidden'); }
      }
    });

    // Cancel button
    document.getElementById('cancel-btn')?.addEventListener('click', function() {
      document.getElementById('cancel-controls')?.classList.remove('hidden');
    });

    document.getElementById('confirm-cancel')?.addEventListener('click', async function() {
      if (!currentOfferId) return;
      var reason = document.getElementById('cancel-reason')?.value || null;
      var res = await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + currentToken },
        body: JSON.stringify({ reason: reason })
      });
      if (res.ok) {
        document.getElementById('offer-detail-section')?.classList.add('hidden');
        document.getElementById('offers-list-section')?.classList.remove('hidden');
        await loadOffers();
      }
    });

    // Admin status save
    document.getElementById('save-status')?.addEventListener('click', async function() {
      if (!currentOfferId) return;
      var status = document.getElementById('status-select')?.value;
      var notes = document.getElementById('admin-notes-input')?.value;
      await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/status', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + currentToken },
        body: JSON.stringify({ status: status, adminNotes: notes || null })
      });
      await showDetail(currentOfferId);
    });

    // Send comment
    document.getElementById('send-comment')?.addEventListener('click', async function() {
      var input = document.getElementById('comment-input');
      var content = input?.value?.trim();
      if (!content || !currentOfferId) return;

      var res = await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + currentToken },
        body: JSON.stringify({ content: content })
      });

      if (res.ok) {
        if (input) input.value = '';
        // Reload comments
        var commentsRes = await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/comments', {
          headers: { 'Authorization': 'Bearer ' + currentToken }
        });
        if (commentsRes.ok) renderComments(await commentsRes.json());
        // Reload history too
        var historyRes = await fetch(apiUrl + '/api/job-offers/' + currentOfferId + '/history', {
          headers: { 'Authorization': 'Bearer ' + currentToken }
        });
        if (historyRes.ok) renderHistory(await historyRes.json());
      }
    });

    // Back to list
    document.getElementById('back-to-list')?.addEventListener('click', function() {
      document.getElementById('offer-detail-section')?.classList.add('hidden');
      document.getElementById('offers-list-section')?.classList.remove('hidden');
    });

    // Status filter buttons
    document.querySelectorAll('.status-filter-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        activeStatus = btn.getAttribute('data-status') || '';
        document.querySelectorAll('.status-filter-btn').forEach(function(b) {
          b.className = 'status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-surface-container-high text-on-surface hover:bg-surface-container-highest';
        });
        btn.className = 'status-filter-btn px-4 py-2 rounded-full text-sm font-label font-semibold transition-colors cursor-pointer bg-primary text-on-primary';
        await loadOffers();
      });
    });

    function esc(str) {
      if (!str) return '';
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }
  </script>

</Layout>
