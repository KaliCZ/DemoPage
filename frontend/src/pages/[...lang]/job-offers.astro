---
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import JobOffersList from "../../components/job-offers/JobOffersList.vue";
import { locales, defaultLocale, localePath, type Locale } from "../../i18n/utils";
import type { PageMeta } from "../../lib/page-meta";
import enStrings from "../../i18n/en/job-offers.json";
import csStrings from "../../i18n/cs/job-offers.json";
import enCommon from "../../i18n/en/common.json";
import csCommon from "../../i18n/cs/common.json";

const translations = { en: enStrings, cs: csStrings };
const commonTranslations = { en: enCommon, cs: csCommon };

export const pageMeta: PageMeta = { updatedDate: "2026-07-07" };

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }));
}

const lang = (Astro.params.lang ?? defaultLocale) as Locale;
const t = translations[lang];
const c = commonTranslations[lang];

const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const detailPath = localePath(lang, "job-offers/detail");
---

<Layout title={t.meta.title} description={t.meta.description} activePage="job-offers" lang={lang}>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-8 mb-16">
    <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none mb-6">
      <span class="gradient-text text-primary bg-linear-to-r from-primary to-tertiary">{t.hero.title}</span>
    </h1>
    <p class="text-lg text-on-surface-variant font-body max-w-xl">
      {t.hero.subtitle}
    </p>
  </section>

  <!-- Loading (shown until auth check completes) -->
  <section id="auth-loading" class="max-w-5xl mx-auto px-8 mb-16">
    <div class="text-center py-12">
      <Icon name="material-symbols:progress-activity" class="size-[30px] text-on-surface-variant animate-spin" aria-hidden="true" />
    </div>
  </section>

  <!-- Login prompt. `signed-out-only` hooks Layout's pre-paint CSS so this
       is shown immediately for signed-out users, before supabase loads. -->
  <section id="login-prompt" class="signed-out-only hidden max-w-5xl mx-auto px-8 mb-16">
    <div class="bg-surface-container-low rounded-2xl border border-outline-variant/10 p-8 md:p-12 text-center">
      <Icon name="material-symbols:lock" class="size-12 text-primary mb-4 mx-auto block" aria-hidden="true" />
      <h2 class="font-headline text-2xl font-bold text-on-surface mb-3">
        {t.loginPrompt.title}
      </h2>
      <p class="text-on-surface-variant font-body mb-6">
        {t.loginPrompt.description}
      </p>
      <button
        id="offers-sign-in"
        type="button"
        class="px-6 py-3 rounded-xl text-sm font-semibold font-label bg-primary text-on-primary hover:bg-primary/90 transition-colors cursor-pointer"
      >
        {t.loginPrompt.signInButton}
      </button>
    </div>
  </section>

  <!-- Offers list. `signed-in-only` keeps it visible for signed-in users
       during the supabase init delay. -->
  <section id="offers-list-section" class="signed-in-only hidden max-w-5xl mx-auto px-8 mb-16">
    <JobOffersList
      client:idle
      apiUrl={apiUrl}
      isAdmin={false}
      detailPath={detailPath}
      hireMeUrl={localePath(lang, "hire-me")}
      lang={lang}
      t={{
        filterByStatus: t.list.filterByStatus,
        statusLabels: {
          Submitted: t.list.submitted,
          InReview: t.list.inReview,
          LetsTalk: t.list.accepted,
          Declined: t.list.declined,
          Cancelled: t.list.cancelled,
        },
        remote: t.list.remote,
        emptyTitle: t.empty.title,
        emptyDescription: t.empty.description,
        emptyCta: t.empty.cta,
        paginationPrev: t.list.paginationPrev,
        paginationNext: t.list.paginationNext,
        paginationPage: t.list.paginationPage,
        errors: c.errors,
        apiErrors: t.errors,
      }}
    />
  </section>

  <script is:inline define:vars={{ detailPath }}>
    // Legacy deep links used a hash (`/job-offers#<id>`); forward them to the detail page.
    var legacyOfferId = location.hash.slice(1);
    if (legacyOfferId) location.replace(detailPath + "?id=" + encodeURIComponent(legacyOfferId));
  </script>

  <script>
    import { openAuthDialog, wireAuthGate } from "../../lib/auth";

    wireAuthGate({ loadingId: "auth-loading", blockedId: "login-prompt", contentId: "offers-list-section" });
    document.getElementById("offers-sign-in")?.addEventListener("click", openAuthDialog);

    // TODO: Remove once uptime monitoring (e.g. Sentry) keeps the DB alive.
    // Wake up the database (see hire-me.astro for details).
    fetch(`${import.meta.env.PUBLIC_API_URL || ""}/health`).catch(() => {});
  </script>
</Layout>
