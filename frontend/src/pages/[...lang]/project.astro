---
import Layout from '../../layouts/Layout.astro';
import { locales, defaultLocale, type Locale } from '../../i18n/utils';
import enStrings from '../../i18n/en/project.json';
import csStrings from '../../i18n/cs/project.json';

const translations = { en: enStrings, cs: csStrings };

export function getStaticPaths() {
  return locales.map(lang => ({
    params: { lang: lang === defaultLocale ? undefined : lang },
  }));
}

const lang = (Astro.params.lang ?? defaultLocale) as Locale;
const t = translations[lang];

---

<Layout title={t.meta.title} description={t.meta.description} activePage="project" lang={lang}>

  <!-- Hero / Intro Section -->
  <section class="max-w-7xl mx-auto px-8 mb-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-8">
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1] text-on-surface">
          {t.hero.titlePrefix}<span class="gradient-text text-primary bg-linear-to-r from-primary to-primary-container">{t.hero.titleHighlight}</span>{t.hero.titleSuffix}
        </h1>
        <p class="font-body text-xl text-on-surface-variant max-w-2xl leading-relaxed">
          {t.hero.description}
        </p>
      </div>
      <div class="md:col-span-4 bg-surface-container p-8 rounded-xl border border-outline-variant/40 shadow-sm">
        <h3 class="font-headline font-bold text-xl mb-6 flex items-center gap-2 text-on-surface">
          <span class="material-symbols-outlined text-tertiary" aria-hidden="true">bolt</span>
          {t.quickStats.title}
        </h3>
        <div class="space-y-6">
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.statusLabel}</div>
            <div class="font-body font-semibold text-primary">{t.quickStats.statusValue}</div>
          </div>
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.versionLabel}</div>
            <div class="font-body font-semibold text-on-surface">{t.quickStats.versionValue}</div>
          </div>
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.timeLabel}</div>
            <div class="font-body font-semibold text-on-surface">{t.quickStats.timeValue}</div>
          </div>
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.costOneTimeLabel}</div>
            <div class="font-body font-semibold text-on-surface">{t.quickStats.costOneTimeValue}</div>
          </div>
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.costRecurringLabel}</div>
            <div class="font-body font-semibold text-on-surface">{t.quickStats.costRecurringValue}</div>
          </div>
          <div>
            <div class="font-label text-xs text-on-surface-variant uppercase mb-1">{t.quickStats.sourceLabel}</div>
            <a href="https://github.com/kalicz/DemoPage" target="_blank" rel="noopener noreferrer" class="font-body font-semibold text-tertiary hover:underline flex items-center gap-1.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              {t.quickStats.sourceValue}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="max-w-7xl mx-auto px-8 mb-32">
    <h2 class="font-headline text-3xl font-bold mb-12 text-on-surface">{t.techStack.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-surface-container p-8 rounded-xl border border-outline-variant/40">
        <h3 class="font-label text-sm uppercase tracking-widest text-primary mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">monitor</span>
          {t.techStack.frontendLabel}
        </h3>
        <ul class="space-y-3">
          {t.techStack.frontendItems.map((item) => (
            <li class="font-body text-on-surface-variant flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-surface-container p-8 rounded-xl border border-outline-variant/40">
        <h3 class="font-label text-sm uppercase tracking-widest text-tertiary mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">dns</span>
          {t.techStack.backendLabel}
        </h3>
        <ul class="space-y-3">
          {t.techStack.backendItems.map((item) => (
            <li class="font-body text-on-surface-variant flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-tertiary shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-surface-container p-8 rounded-xl border border-outline-variant/40">
        <h3 class="font-label text-sm uppercase tracking-widest text-on-surface-variant mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">settings</span>
          {t.techStack.infraLabel}
        </h3>
        <ul class="space-y-3">
          {t.techStack.infraItems.map((item) => (
            <li class="font-body text-on-surface-variant">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-outline shrink-0"></span>
                {item.text}
              </div>
              {item.subItems && (
                <ul class="ml-5 mt-2 space-y-2">
                  {item.subItems.map((sub) => (
                    <li class="flex items-center gap-2 text-sm">
                      <span class="w-1 h-1 rounded-full bg-outline/60 shrink-0"></span>
                      {sub}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Roadmap Section -->
  <section class="max-w-7xl mx-auto px-8">
    <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-4">
      <div>
        <span class="font-label text-tertiary uppercase tracking-widest text-sm mb-4 block">{t.roadmap.timelineLabel}</span>
        <h2 class="font-headline text-4xl font-extrabold tracking-tight text-on-surface">{t.roadmap.title}</h2>
      </div>
      <p class="font-body text-on-surface-variant max-w-sm text-right">
        {t.roadmap.subtitle}
      </p>
    </div>

    <div class="relative">
      <!-- Vertical Line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-outline-variant/30 -translate-x-1/2 hidden md:block"></div>

      <div class="space-y-24">
        {t.roadmap.versions.map((version) => {
          const isLeft = version.side === 'left';
          const isFaded = 'faded' in version && version.faded;
          const hasPricing = 'pricingTable' in version && version.pricingTable;
          const hasDetails = 'details' in version && version.details;

          return (
            <div class:list={["relative grid grid-cols-1 md:grid-cols-2 gap-8 items-start", isFaded && "opacity-60"]}>
              {isLeft ? (
                <>
                  <div class="md:text-right md:pr-16">
                    <div class:list={["font-label text-primary mb-2 text-sm uppercase", version.done && "flex items-center gap-1.5 md:justify-end"]}>
                      {`Version ${version.number}`}
                      {version.done && (
                        <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                      )}
                    </div>
                    <h3 class:list={["font-headline text-2xl font-bold text-on-surface", version.done ? "mb-2" : "mb-4"]}>{version.title}</h3>
                    {'time' in version && version.time && <p class:list={["font-label text-xs text-on-surface-variant", 'nextTime' in version && version.nextTime ? "mb-1" : "mb-4"]}>{version.time}</p>}
                    {'nextTime' in version && version.nextTime && <p class="font-label text-xs text-on-surface-variant/60 italic mb-4">{version.nextTime}</p>}
                    <p class:list={["font-body text-on-surface-variant leading-relaxed", (hasPricing || hasDetails) && "mb-4"]}>{version.description}</p>
                    {hasDetails && (
                      <details class="group bg-surface-container-high rounded-xl border border-primary/20 text-left shadow-md inline-block">
                        <summary class="p-6 cursor-pointer font-label text-xs uppercase tracking-widest text-on-surface flex items-center gap-2 select-none">
                          <span class="material-symbols-outlined text-[16px] text-primary transition-transform group-open:rotate-180" aria-hidden="true">expand_more</span>
                          {version.detailsLabel}
                        </summary>
                        <ul class="px-6 pb-6 space-y-3 font-body text-sm text-on-surface-variant">
                          {version.details!.map((item) => (
                            <li class="flex items-center gap-2">
                              {item.author === 'claude' ? (
                                <img src="/images/claude-icon.svg" alt="Claude" class="w-4 h-4 rounded-full" />
                              ) : (
                                <img src="/images/pavel-portrait-200.webp" alt="Pavel" class="w-4 h-4 rounded-full object-cover" width="16" height="16" />
                              )}
                              <span>{item.text}</span>
                            </li>
                          ))}
                        </ul>
                      </details>
                    )}
                    {hasPricing && (
                      <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/20 text-sm">
                        <table class="w-full font-body text-on-surface-variant">
                          <thead>
                            <tr class="text-left font-label text-xs uppercase tracking-wider">
                              {version.pricingTable!.headers.map((h) => <th scope="col" class="pb-2">{h}</th>)}
                            </tr>
                          </thead>
                          <tbody class="text-sm">
                            {version.pricingTable!.rows.map((row) => (
                              <tr>
                                {row.map((cell) => <td class="py-1">{cell}</td>)}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    )}
                  </div>
                  {version.done ? (
                    <div class="absolute top-5 left-4 md:left-1/2 w-8 h-8 rounded-full bg-primary border-4 border-background shadow-[0_0_15px_rgba(72,88,171,0.2)] -translate-x-1/2 z-10 hidden md:flex items-center justify-center">
                      <span class="material-symbols-outlined text-white text-[14px]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check</span>
                    </div>
                  ) : (
                    <div class="absolute top-7 left-4 md:left-1/2 w-4 h-4 rounded-full bg-outline border-4 border-background -translate-x-1/2 z-10 hidden md:block"></div>
                  )}
                  <div></div>
                </>
              ) : (
                <>
                  <div></div>
                  {version.done ? (
                    <div class="absolute top-5 left-4 md:left-1/2 w-8 h-8 rounded-full bg-primary border-4 border-background shadow-[0_0_15px_rgba(72,88,171,0.2)] -translate-x-1/2 z-10 hidden md:flex items-center justify-center">
                      <span class="material-symbols-outlined text-white text-[14px]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check</span>
                    </div>
                  ) : (
                    <div class="absolute top-7 left-4 md:left-1/2 w-4 h-4 rounded-full bg-outline border-4 border-background -translate-x-1/2 z-10 hidden md:block"></div>
                  )}
                  <div class="md:pl-16">
                    <div class:list={["font-label text-primary mb-2 text-sm uppercase", version.done && "flex items-center gap-1.5"]}>
                      {`Version ${version.number}`}
                      {version.done && (
                        <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                      )}
                    </div>
                    <h3 class:list={["font-headline text-2xl font-bold text-on-surface", version.done ? "mb-2" : "mb-4"]}>{version.title}</h3>
                    {'time' in version && version.time && <p class:list={["font-label text-xs text-on-surface-variant", 'nextTime' in version && version.nextTime ? "mb-1" : "mb-4"]}>{version.time}</p>}
                    {'nextTime' in version && version.nextTime && <p class="font-label text-xs text-on-surface-variant/60 italic mb-4">{version.nextTime}</p>}
                    <p class:list={["font-body text-on-surface-variant leading-relaxed", (hasPricing || hasDetails) && "mb-4"]}>{version.description}</p>
                    {hasDetails && (
                      <details class="group bg-surface-container-high rounded-xl border border-primary/20 text-left shadow-md inline-block">
                        <summary class="p-6 cursor-pointer font-label text-xs uppercase tracking-widest text-on-surface flex items-center gap-2 select-none">
                          <span class="material-symbols-outlined text-[16px] text-primary transition-transform group-open:rotate-180" aria-hidden="true">expand_more</span>
                          {version.detailsLabel}
                        </summary>
                        <ul class="px-6 pb-6 space-y-3 font-body text-sm text-on-surface-variant">
                          {version.details!.map((item) => (
                            <li class="flex items-center gap-2">
                              {item.author === 'claude' ? (
                                <img src="/images/claude-icon.svg" alt="Claude" class="w-4 h-4 rounded-full" />
                              ) : (
                                <img src="/images/pavel-portrait-200.webp" alt="Pavel" class="w-4 h-4 rounded-full object-cover" width="16" height="16" />
                              )}
                              <span>{item.text}</span>
                            </li>
                          ))}
                        </ul>
                      </details>
                    )}
                  </div>
                </>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="max-w-7xl mx-auto px-8 mt-32">
    <div class="bg-linear-to-br from-primary-container to-surface-container-low p-12 rounded-2xl relative overflow-hidden border border-primary/10 shadow-lg">
      <div class="relative z-10 flex flex-col items-center text-center">
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold mb-6 tracking-tight text-on-surface">{t.cta.title}</h2>
        <p class="font-body text-on-surface-variant max-w-xl mb-10 text-lg">
          {t.cta.description}
        </p>
        <a
          href="https://github.com/kalicz/DemoPage"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary text-on-primary px-8 py-4 font-headline font-bold rounded-lg shadow-md hover:opacity-90 transition-all hover:scale-[1.02] active:scale-95"
        >
          {t.cta.button}
        </a>
      </div>
      <!-- Abstract visual element -->
      <div class="absolute -right-24 -bottom-24 w-96 h-96 bg-tertiary/10 blur-[100px] rounded-full"></div>
    </div>
  </section>

</Layout>
